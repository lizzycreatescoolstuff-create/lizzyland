<%
  var pageTitle   = 'Health — Lizzyland';
  var pageDesc    = 'Curated wellness tools to help you detox from your past and float into your bliss.';
  var currentPage = 'health';
%>
<%- include('partials/header') %>

<style>
  /* ── Hero ── */
  .ll-health-hero {
    position: relative; min-height: 220px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; background: var(--ocean);
  }
  .ll-health-hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 40%;
  }
  .ll-health-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(45,27,14,0.82) 0%, rgba(26,138,122,0.3) 55%, rgba(200,149,42,0.08) 100%);
  }
  .ll-health-hero-inner {
    position: relative; z-index: 2;
    max-width: 1100px; margin: 0 auto;
    width: 100%; padding: 2.5rem 2rem; color: var(--white);
    text-align: center;
  }
  .ll-health-hero-eyebrow {
    font-family: var(--font-accent); font-style: italic;
    font-size: 0.9rem; color: var(--gold-light);
    letter-spacing: 0.15em; text-transform: uppercase;
    opacity: 0.8; margin-bottom: 0.4rem;
  }
  .ll-health-hero-inner h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.2rem);
    color: var(--white); margin: 0 0 0.4rem;
    text-shadow: 0 2px 16px rgba(0,0,0,0.3);
  }
  .ll-health-hero-inner p {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.1rem; color: rgba(255,255,255,0.85) !important; margin: 0;
  }

  /* ── Intro ── */
  .ll-health-intro {
    padding: 4rem 2rem 3rem;
    background: var(--sand-light); text-align: center;
  }
  .ll-health-intro-inner { max-width: 720px; margin: 0 auto; }
  .ll-health-intro-eyebrow {
    font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.2em;
    color: var(--gold); margin-bottom: 0.75rem;
  }
  .ll-health-intro h2 {
    font-family: var(--font-display); font-size: clamp(1.6rem, 3vw, 2.4rem);
    color: var(--warm-dark); margin-bottom: 1rem; font-weight: 600;
  }
  .ll-health-lead {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.15rem; color: var(--text-soft); line-height: 1.85;
  }

  /* ── Magazine sections ── */
  .ll-wellness-section { padding: 3.5rem 2rem; }
  .ll-wellness-section:nth-child(odd)  { background: var(--cream); }
  .ll-wellness-section:nth-child(even) { background: var(--sand-light); }

  .ll-wellness-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
  }
  .ll-wellness-inner.reverse { direction: rtl; }
  .ll-wellness-inner.reverse > * { direction: ltr; }

  .ll-wellness-img {
    width: 100%; border-radius: var(--radius-md);
    object-fit: cover; aspect-ratio: 4/5;
    box-shadow: 0 12px 48px rgba(0,0,0,0.12);
    display: block;
  }

  .ll-wellness-eyebrow {
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.22em;
    color: var(--gold); margin-bottom: 0.75rem;
  }
  .ll-wellness-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    color: var(--warm-dark); font-weight: 600;
    line-height: 1.15; margin-bottom: 0.6rem;
  }
  .ll-wellness-tagline {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.1rem; color: var(--ocean);
    margin-bottom: 1.5rem; line-height: 1.5;
  }
  .ll-wellness-desc {
    font-size: 0.97rem; color: var(--text-soft);
    line-height: 1.85; margin-bottom: 1.75rem;
  }
  .ll-wellness-benefits {
    list-style: none; margin-bottom: 2rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.35rem 1.5rem;
  }
  .ll-wellness-benefits li {
    font-size: 0.85rem; color: var(--text-soft);
    padding: 0.3rem 0; border-bottom: 1px solid var(--sand-deep);
    display: flex; align-items: center; gap: 0.4rem;
  }
  .ll-wellness-benefits li::before { content: '✦'; color: var(--gold); font-size: 0.55rem; flex-shrink: 0; }

  .ll-wellness-video {
    margin-bottom: 1.75rem;
    border-radius: var(--radius-sm); overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  }
  .ll-wellness-video iframe { display: block; width: 100%; aspect-ratio: 16/9; border: none; }

  .ll-wellness-cta {
    display: inline-block; background: var(--ocean);
    color: var(--white) !important; padding: 0.8rem 2.2rem;
    border-radius: 50px; font-weight: 600; font-size: 0.9rem;
    letter-spacing: 0.04em; text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .ll-wellness-cta:hover { background: var(--gold); transform: translateY(-2px); }

  .ll-wellness-affiliate-note {
    display: block; margin-top: 0.75rem;
    font-size: 0.72rem; color: var(--text-muted); font-style: italic;
  }

  /* ── Sleep sanctuary ── */
  .ll-sleep-section { padding: 3.5rem 2rem; background: var(--white); }
  .ll-sleep-inner { max-width: 900px; margin: 0 auto; }
  .ll-sleep-header { text-align: center; margin-bottom: 3rem; }
  .ll-sleep-banner {
    width: 100%; border-radius: var(--radius-md);
    object-fit: cover; max-height: 420px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    margin-bottom: 2.5rem; display: block;
  }
  .ll-sleep-benefits {
    list-style: none; margin: 1.5rem 0 2rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.35rem 2rem;
  }
  .ll-sleep-benefits li {
    font-size: 0.85rem; color: var(--text-soft);
    padding: 0.3rem 0; border-bottom: 1px solid var(--sand-deep);
    display: flex; align-items: center; gap: 0.4rem;
  }
  .ll-sleep-benefits li::before { content: '✦'; color: var(--gold); font-size: 0.55rem; flex-shrink: 0; }

  .ll-sleep-divider {
    max-width: 120px; margin: 3rem auto;
    border: none; border-top: 1px solid var(--sand-deep);
  }

  .ll-sleep-grid {
    display: grid; grid-template-columns: repeat(3,1fr);
    gap: 1.5rem; margin: 2.5rem 0 0.75rem;
  }
  .ll-sleep-card { text-align: center; }
  .ll-sleep-card a { text-decoration: none; }
  .ll-sleep-card img {
    width: 100%; border-radius: var(--radius-sm);
    object-fit: cover; aspect-ratio: 1/1;
    box-shadow: 0 4px 16px rgba(0,0,0,0.09);
    margin-bottom: 0.75rem; transition: transform 0.3s;
    display: block;
  }
  .ll-sleep-card img:hover { transform: scale(1.02); }
  .ll-sleep-card-name { font-size: 0.85rem; font-weight: 600; color: var(--warm-dark); margin-bottom: 0.2rem; }
  .ll-sleep-card-tagline { font-size: 0.75rem; color: var(--text-muted); font-style: italic; margin-bottom: 0.6rem; }
  .ll-sleep-card-btn {
    display: inline-block; background: var(--ocean); color: white;
    padding: 0.35rem 1rem; border-radius: 50px;
    font-size: 0.75rem; font-weight: 600; transition: background 0.2s;
  }
  .ll-sleep-card-btn:hover { background: var(--gold); }

  /* ── Philosophy strip ── */
  .ll-health-philosophy {
    background: linear-gradient(135deg, var(--ocean) 0%, #0d6b5e 100%);
    padding: 3rem 2rem;
  }
  .ll-health-philosophy-inner { max-width: 620px; margin: 0 auto; text-align: center; }
  .ll-philosophy-quote {
    font-family: var(--font-accent); font-style: italic;
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    color: var(--white); line-height: 1.6; margin-bottom: 0.75rem;
  }
  .ll-philosophy-byline { font-family: var(--font-display); font-size: 1rem; color: var(--gold-light); font-style: italic; }

  /* ── Back to doors ── */
  .ll-back-to-doors { padding: 2.5rem 2rem; background: var(--sand-light); }
  .ll-back-inner { max-width: 500px; margin: 0 auto; text-align: center; }
  .ll-back-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text-muted); margin-bottom: 1rem; }
  .ll-back-links { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .ll-back-link {
    display: inline-block; padding: 0.5rem 1.25rem;
    border-radius: 50px; background: var(--white);
    border: 2px solid var(--sand-deep); color: var(--text-soft);
    font-weight: 500; font-size: 0.85rem; text-decoration: none; transition: all 0.2s;
  }
  .ll-back-link:hover { border-color: var(--ocean); color: var(--ocean); }
  .ll-back-home { border-color: var(--gold); color: var(--gold); }
  .ll-back-home:hover { background: var(--gold); color: var(--white); }

  @media (max-width: 768px) {
    .ll-wellness-inner { grid-template-columns: 1fr; gap: 2rem; }
    .ll-wellness-inner.reverse { direction: ltr; }
    .ll-wellness-benefits { grid-template-columns: 1fr; }
    .ll-wellness-img { aspect-ratio: 16/9; }
    .ll-sleep-benefits { grid-template-columns: 1fr; }
    .ll-sleep-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .ll-sleep-grid { grid-template-columns: 1fr; }
  }
</style>

