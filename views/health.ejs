  .ll-health-cta-soon { background: var(--sand-deep); color: var(--text-muted) !important; cursor: default; }
  .ll-health-cta-soon:hover { background: var(--sand-deep); transform: none; }


  .ll-health-product-img {
    width: 100%; max-width: 480px;
    border-radius: var(--radius-sm);
    object-fit: cover;
    margin: 1.25rem 0;
    box-shadow: 0 4px 20px rgba(0,0,0,0.10);
