<%- include('partials/header') %>

<style>
  /* ── Health hero — beach banner, shop-hero proportions ── */
  .ll-health-hero {
    position: relative;
    min-height: 280px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--ocean);
  }
  .ll-health-hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 40%;
  }
  .ll-health-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to top,
      rgba(45,27,14,0.82) 0%,
      rgba(26,138,122,0.3) 55%,
      rgba(200,149,42,0.08) 100%
    );
  }
  .ll-health-hero-inner {
    position: relative; z-index: 2;
    max-width: 1100px; margin: 0 auto;
    width: 100%; padding: 2.5rem 2rem;
    color: var(--white);
  }
  .ll-health-hero-eyebrow {
    font-family: var(--font-accent); font-style: italic;
    font-size: 0.9rem; color: var(--gold-light);
    letter-spacing: 0.15em; text-transform: uppercase;
    opacity: 0.8; margin-bottom: 0.4rem;
  }
  .ll-health-hero-inner h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.2rem);
    color: var(--white); margin: 0 0 0.4rem;
    text-shadow: 0 2px 16px rgba(0,0,0,0.3);
  }
  .ll-health-hero-inner p {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.1rem; opacity: 0.85; margin: 0;
  }

  /* ── Intro ── */
