    display: flex; align-items: center; justify-content: center;
    margin: 1.25rem 0; font-size: 0.85rem; color: var(--text-muted);
    font-style: italic; border: 2px dashed var(--sand-deep);
  }

  .ll-health-cta-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-top: 1.25rem; }

  .ll-health-cta {
    display: inline-block; background: var(--ocean);
    color: var(--white) !important; padding: 0.7rem 1.8rem;
    border-radius: 50px; font-weight: 600; font-size: 0.88rem;
    letter-spacing: 0.05em; text-decoration: none;
    transition: background 0.2s, transform 0.2s;
