    display: none;
    padding: 0 2rem 2rem;
    border-top: 1px solid var(--sand-deep);
  }
  .ll-health-block.open .ll-health-block-body { display: block; }

  .ll-health-block-desc {
    font-size: 0.95rem; color: var(--text-soft);
    line-height: 1.8; margin: 1.25rem 0;
  }

  .ll-health-benefits {
    list-style: none; margin-bottom: 1.5rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem 1.5rem;
  }
  .ll-health-benefits li {
    font-size: 0.87rem; color: var(--text-soft);
    padding: 0.3rem 0; border-bottom: 1px solid var(--sand-deep);
    display: flex; align-items: center; gap: 0.4rem;
