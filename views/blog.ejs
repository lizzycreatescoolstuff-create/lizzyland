<% var pageTitle = 'Blog — Lizzyland'; var currentPage = 'blog'; %>
<%- include('partials/header') %>

<style>
/* ── Hero ── */
.ll-blog-hero {
  position: relative; min-height: 220px;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; background: var(--ocean);
}
.ll-blog-hero-img {
  position: absolute; inset: 0; width: 100%; height: 100%;
  object-fit: cover; object-position: center 40%;
}
.ll-blog-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(45,27,14,0.82) 0%, rgba(26,138,122,0.3) 55%, rgba(200,149,42,0.08) 100%);
}
.ll-blog-hero-inner {
  position: relative; z-index: 2;
  max-width: 1100px; margin: 0 auto;
  width: 100%; padding: 2.5rem 2rem;
  color: var(--white); text-align: center;
}
.ll-blog-hero-eyebrow {
  font-family: var(--font-accent); font-style: italic;
  font-size: 0.9rem; color: var(--gold-light);
  letter-spacing: 0.15em; opacity: 0.8; margin-bottom: 0.4rem;
}
.ll-blog-hero-inner h1 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.2rem);
  color: var(--white); margin: 0 0 0.4rem;
  text-shadow: 0 2px 20px rgba(0,0,0,0.5);
}
.ll-blog-hero-inner p {
  font-family: var(--font-accent); font-style: italic;
  font-size: 1.1rem; opacity: 0.85; margin: 0;
}

/* ── Blog grid ── */
.ll-blog-grid {
  max-width: 1100px; margin: 0 auto; padding: 3rem 1.5rem;
  display: grid; grid-template-columns: repeat(auto-fill, minmax(320px,1fr)); gap: 2rem;
  background: var(--cream);
}
.ll-blog-card {
  background: var(--sand-light); border-radius: var(--radius-lg);
  overflow: hidden; transition: transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 2px 12px rgba(45,27,14,0.08);
  text-decoration: none; display: block; color: inherit;
}
.ll-blog-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(45,27,14,0.14); }
.ll-blog-card-img { aspect-ratio: 16/9; background: #e8ddd0; overflow: hidden; }
.ll-blog-card-img img { width: 100%; height: 100%; object-fit: cover; }
.ll-blog-card-body { padding: 1.1rem 1.25rem 1.4rem; }
.ll-blog-card-cat {
  font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--gold); margin-bottom: 0.4rem;
}
.ll-blog-card-title {
  font-family: var(--font-heading); font-size: 1.1rem;
  color: var(--warm-dark); margin-bottom: 0.5rem; line-height: 1.25;
}
.ll-blog-card-date { font-size: 0.75rem; color: var(--text-muted); }
.ll-blog-empty {
  text-align: center; padding: 5rem 2rem; opacity: 0.5;
  font-family: var(--font-accent); font-style: italic; font-size: 1.1rem;
}
</style>

<!-- ══ HERO ══ -->
<section class="ll-blog-hero">
  <img src="/images/blog-banner.webp" alt="The Lizzyland Journal" class="ll-blog-hero-img" onerror="this.style.display='none'">
  <div class="ll-blog-hero-overlay"></div>
  <div class="ll-blog-hero-inner">
    <div class="ll-blog-hero-eyebrow">✦ Musings & Dispatches ✦</div>
    <h1>The Lizzyland Journal</h1>
    <p>From the bath. From the beach. From the beautiful ordinary.</p>
  </div>
</section>

<!-- ══ POSTS ══ -->
<div class="ll-blog-grid" style="background:var(--cream);">
  <% if (typeof posts !== 'undefined' && posts && posts.length > 0) { %>
    <% posts.forEach(function(post) { %>
    <a href="/blog/<%= post.slug %>" class="ll-blog-card">
      <div class="ll-blog-card-img">
        <% if (post.image_url) { %><img src="<%= post.image_url %>" alt="<%= post.title %>" loading="lazy"><% } %>
      </div>
      <div class="ll-blog-card-body">
        <div class="ll-blog-card-cat"><%= post.category || 'general' %></div>
        <div class="ll-blog-card-title"><%= post.title %></div>
        <div class="ll-blog-card-date"><%= post.created_at ? new Date(post.created_at).toLocaleDateString('en-ZA',{day:'numeric',month:'long',year:'numeric'}) : '' %></div>
      </div>
    </a>
    <% }); %>
  <% } else { %>
    <div class="ll-blog-empty" style="grid-column:1/-1;">No posts yet — the journal is warming up. 🌴</div>
  <% } %>
</div>

<%- include('partials/footer') %>
