<%
  var pageTitle   = 'Solutions — Lizzyland';
  var pageDesc    = 'Your beautiful life is closer than you think.';
  var currentPage = 'solutions';
%>
<%- include('partials/header') %>

<style>
  /* ══ Hero ══ */
  .ll-sol-hero {
    position: relative; min-height: 260px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    background: linear-gradient(160deg, #0d1a14 0%, #0a2218 50%, #0d1a14 100%);
  }
  .ll-sol-hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 45%;
  }
  .ll-sol-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,20,16,0.88) 0%, rgba(10,20,16,0.5) 55%, rgba(0,0,0,0.25) 100%);
  }
  .ll-sol-hero-inner {
    position: relative; z-index: 2; text-align: center;
    max-width: 720px; margin: 0 auto; padding: 3rem 2rem;
  }
  .ll-sol-hero-eyebrow {
    font-family: var(--font-accent); font-style: italic;
    font-size: 0.85rem; color: var(--gold-light);
    letter-spacing: 0.2em; opacity: 0.7; margin-bottom: 0.75rem;
  }
  .ll-sol-hero-inner h1 {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 3rem);
    color: var(--white); margin: 0 0 0.75rem;
    text-shadow: 0 2px 24px rgba(0,0,0,0.6); line-height: 1.2;
  }
  .ll-sol-hero-inner p {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.05rem; color: rgba(255,255,255,0.65); margin: 0;
  }

  /* ══ Shared section styles ══ */
  .ll-sol-section { padding: 4.5rem 2rem; }
  .ll-sol-section.cream  { background: var(--cream); }
  .ll-sol-section.sand   { background: var(--sand-light); }
  .ll-sol-section.white  { background: var(--white); }
  .ll-sol-section.dark   { background: linear-gradient(160deg, #0d1a14 0%, #0a2218 100%); }
  .ll-sol-section.teal   { background: linear-gradient(135deg, var(--ocean) 0%, #0d6b5e 100%); }
  .ll-sol-section.gold-bg { background: linear-gradient(135deg, #2a1f08 0%, #1a1408 100%); }

  .ll-sol-inner { max-width: 1100px; margin: 0 auto; }
  .ll-sol-narrow { max-width: 820px; margin: 0 auto; }

  .ll-sol-header { margin-bottom: 3rem; }
  .ll-sol-header.center { text-align: center; }

  .ll-sol-eyebrow {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.25em; color: var(--gold); margin-bottom: 0.6rem;
  }
  .ll-sol-eyebrow.light { color: var(--gold-light); opacity: 0.8; }

  .ll-sol-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    color: var(--warm-dark); font-weight: 600; line-height: 1.15; margin-bottom: 0.5rem;
  }
  .ll-sol-title.light { color: var(--white); }

  .ll-sol-tagline {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.05rem; color: var(--text-soft); line-height: 1.6;
  }
  .ll-sol-tagline.light { color: rgba(255,255,255,0.65); }

  .ll-sol-desc {
    font-size: 0.95rem; color: var(--text-soft);
    line-height: 1.85; margin-bottom: 1.5rem;
  }
  .ll-sol-desc.light { color: rgba(255,255,255,0.6); }

  /* ══ Package cards ══ */
  .ll-pkg-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .ll-pkg-grid.two { grid-template-columns: repeat(2,1fr); max-width: 780px; margin-left: auto; margin-right: auto; }

  .ll-pkg-card {
    background: var(--white); border-radius: var(--radius-md);
    padding: 2rem 1.75rem; border: 1px solid var(--sand-deep);
    box-shadow: 0 2px 16px rgba(0,0,0,0.05);
    transition: all 0.25s; position: relative; overflow: hidden;
  }
  .ll-pkg-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--ocean));
  }
  .ll-pkg-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
  .ll-pkg-card.dark-card {
    background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12);
    box-shadow: none;
  }
  .ll-pkg-card.dark-card:hover { background: rgba(255,255,255,0.09); }
  .ll-pkg-card.dark-card::before { background: linear-gradient(90deg, var(--gold-light), rgba(255,255,255,0.3)); }

  .ll-pkg-icon { font-size: 2rem; margin-bottom: 0.85rem; }
  .ll-pkg-tag {
    display: inline-block; padding: 0.18rem 0.65rem;
    background: rgba(26,138,122,0.1); color: var(--ocean);
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; border-radius: 30px; margin-bottom: 0.75rem;
  }
  .ll-pkg-tag.gold-tag { background: rgba(200,149,42,0.12); color: var(--gold); }
  .ll-pkg-tag.dark-tag { background: rgba(200,149,42,0.2); color: var(--gold-light); }

  .ll-pkg-name {
    font-family: var(--font-display); font-size: 1.2rem;
    color: var(--warm-dark); font-weight: 600; margin-bottom: 0.5rem; line-height: 1.2;
  }
  .ll-pkg-name.light { color: var(--white); }

  .ll-pkg-desc {
    font-size: 0.85rem; color: var(--text-soft); line-height: 1.75; margin-bottom: 1.25rem;
  }
  .ll-pkg-desc.light { color: rgba(255,255,255,0.55); }

  .ll-pkg-list { list-style: none; margin-bottom: 1.25rem; }
  .ll-pkg-list li {
    font-size: 0.82rem; color: var(--text-muted);
    padding: 0.28rem 0; border-bottom: 1px solid var(--sand-deep);
    display: flex; align-items: center; gap: 0.4rem;
  }
  .ll-pkg-list li::before { content: '✦'; color: var(--gold); font-size: 0.5rem; flex-shrink: 0; }
  .ll-pkg-list.light li { color: rgba(255,255,255,0.5); border-bottom-color: rgba(255,255,255,0.1); }
  .ll-pkg-list.light li::before { color: var(--gold-light); }

  .ll-pkg-btn {
    display: inline-block; padding: 0.6rem 1.4rem;
    background: var(--ocean); color: white !important;
    border-radius: 30px; font-size: 0.82rem; font-weight: 600;
    text-decoration: none; transition: background 0.2s;
  }
  .ll-pkg-btn:hover { background: var(--gold); }
  .ll-pkg-btn.gold-btn { background: var(--gold); color: var(--warm-dark) !important; }
  .ll-pkg-btn.gold-btn:hover { background: var(--gold-light); }
  .ll-pkg-btn.soon { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.5) !important; cursor: default; }
  .ll-pkg-btn.soon:hover { background: rgba(255,255,255,0.15); }

  /* ══ Numerology bot ══ */
  .ll-num-bot {
    background: var(--white); border-radius: var(--radius-md);
    box-shadow: 0 8px 40px rgba(0,0,0,0.1); overflow: hidden;
    max-width: 700px; margin: 2.5rem auto 0;
  }
  .ll-num-bot-tabs {
    display: flex; background: var(--sand-light);
    border-bottom: 1px solid var(--sand-deep);
  }
  .ll-num-tab {
    flex: 1; padding: 0.85rem 1rem; font-size: 0.82rem; font-weight: 600;
    text-align: center; cursor: pointer; border: none; background: none;
    color: var(--text-muted); transition: all 0.2s;
    border-bottom: 2px solid transparent;
  }
  .ll-num-tab.active { color: var(--ocean); border-bottom-color: var(--ocean); background: var(--white); }

  .ll-num-panel { display: none; padding: 2rem; }
  .ll-num-panel.active { display: block; }

  .ll-num-field { margin-bottom: 1.25rem; }
  .ll-num-field label {
    display: block; font-size: 0.83rem; font-weight: 600;
    color: var(--text-soft); margin-bottom: 0.4rem;
  }
  .ll-num-field input, .ll-num-field select {
    width: 100%; padding: 0.6rem 0.9rem;
    border: 1.5px solid var(--sand-deep); border-radius: var(--radius-sm);
    font-size: 0.88rem; background: var(--sand-light); outline: none;
    font-family: var(--font-body); transition: border-color 0.2s;
  }
  .ll-num-field input:focus, .ll-num-field select:focus { border-color: var(--ocean); }
  .ll-num-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .ll-num-field small {
    display: block; font-size: 0.73rem; color: var(--text-muted);
    font-style: italic; margin-top: 0.25rem;
  }

  .ll-num-run-btn {
    width: 100%; padding: 0.8rem; background: var(--ocean); color: white;
    border: none; border-radius: 30px; font-weight: 600; font-size: 0.9rem;
    cursor: pointer; margin-top: 0.5rem; transition: background 0.2s;
    font-family: var(--font-body);
  }
  .ll-num-run-btn:hover { background: var(--gold); }
  .ll-num-run-btn:disabled { opacity: 0.6; cursor: wait; }

  .ll-num-output {
    display: none; margin-top: 1.75rem; padding: 1.5rem;
    background: linear-gradient(135deg, #0d1a14, #0a2218);
    border-radius: var(--radius-sm); color: white;
  }
  .ll-num-output.show { display: block; }
  .ll-num-output-title {
    font-family: var(--font-display); font-size: 1.1rem;
    color: var(--gold-light); margin-bottom: 1rem;
  }
  .ll-num-output-body {
    font-size: 0.88rem; line-height: 1.85; color: rgba(255,255,255,0.8);
    white-space: pre-wrap;
  }
  .ll-num-output-cities {
    display: grid; grid-template-columns: repeat(3,1fr);
    gap: 0.75rem; margin-top: 1.25rem;
  }
  .ll-num-city {
    background: rgba(255,255,255,0.08); border-radius: var(--radius-sm);
    padding: 0.75rem; text-align: center; border: 1px solid rgba(255,255,255,0.1);
  }
  .ll-num-city-name { font-weight: 700; font-size: 0.88rem; color: var(--white); margin-bottom: 0.2rem; }
  .ll-num-city-detail { font-size: 0.72rem; color: rgba(255,255,255,0.5); line-height: 1.4; }
  .ll-num-city-link {
    display: inline-block; margin-top: 0.5rem; font-size: 0.7rem;
    color: var(--gold-light); text-decoration: none;
    border-bottom: 1px solid rgba(200,149,42,0.4);
  }

  /* ══ Divider ══ */
  .ll-sol-ornament {
    text-align: center; padding: 2rem 0; font-size: 0.75rem;
    letter-spacing: 0.4em; color: var(--text-muted); opacity: 0.5;
  }

  /* ══ Giving section ══ */
  .ll-giving-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin-top: 2.5rem;
  }
  .ll-giving-card {
    text-align: center; padding: 2rem 1.5rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-md); transition: all 0.25s;
  }
  .ll-giving-card:hover { background: rgba(255,255,255,0.1); transform: translateY(-3px); }
  .ll-giving-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
  .ll-giving-name {
    font-family: var(--font-display); font-size: 1.1rem;
    color: var(--white); margin-bottom: 0.5rem;
  }
  .ll-giving-desc { font-size: 0.83rem; color: rgba(255,255,255,0.5); line-height: 1.7; margin-bottom: 1rem; }

  /* ══ Footer CTA ══ */
  .ll-sol-footer-cta {
    background: var(--sand-light); padding: 3rem 2rem; text-align: center;
  }
  .ll-sol-footer-cta p {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.05rem; color: var(--text-soft); margin-bottom: 1.25rem;
  }

  @media (max-width: 860px) {
    .ll-pkg-grid, .ll-pkg-grid.two { grid-template-columns: 1fr; }
    .ll-giving-grid { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; }
    .ll-num-output-cities { grid-template-columns: 1fr 1fr; }
    .ll-num-field-row { grid-template-columns: 1fr; }
  }
</style>

<!-- ══ HERO ══ -->
<section class="ll-sol-hero">
  <img src="/images/beach-banner-alt.webp" alt="Solutions — Lizzyland" class="ll-sol-hero-img" onerror="this.style.display='none'">
  <div class="ll-sol-hero-overlay"></div>
  <div class="ll-sol-hero-inner">
    <div class="ll-sol-hero-eyebrow">✦ Your Prescription ✦</div>
    <h1>Your beautiful life<br>is closer than you think.</h1>
    <p>You've done the work of knowing what's missing. Here's how we fix it.</p>
  </div>
</section>

<div class="ll-sol-ornament">✦ · ✦ · ✦</div>

