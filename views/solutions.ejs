<script>
/* ══ Tab switcher ══ */
function switchTab(name) {
  document.querySelectorAll('.ll-num-tab').forEach(function(t) { t.classList.remove('active'); });
  document.querySelectorAll('.ll-num-panel').forEach(function(p) { p.classList.remove('active'); });
  var tabs = document.querySelectorAll('.ll-num-tab');
  var map = { 'profile': 0, 'prefs': 1, 'results': 2 };
  tabs[map[name]].classList.add('active');
  document.getElementById('panel-' + name).classList.add('active');
}

/* ══ Life path preview ══ */
function calcLifePath() {
  var d = document.getElementById('nb-dob').value;
  if (!d) return;
  var digits = d.replace(/-/g,'').split('').map(Number);
  var sum = digits.reduce(function(a,b){return a+b;},0);
  function reduce(n) {
    if (n === 11 || n === 22 || n === 33) return n;
    if (n < 10) return n;
    return reduce(String(n).split('').reduce(function(a,b){return a+Number(b);},0));
  }
  var lp = reduce(sum);
  var names = {1:'The Leader',2:'The Diplomat',3:'The Creator',4:'The Builder',5:'The Adventurer',6:'The Nurturer',7:'The Seeker',8:'The Achiever',9:'The Humanitarian',11:'The Intuitive',22:'The Master Builder',33:'The Master Teacher'};
  document.getElementById('nb-lifepath-preview').textContent = 'Life Path ' + lp + ' — ' + (names[lp] || '');
}

/* ══ Chinese zodiac ══ */
function getZodiac(year) {
  var animals = ['Rat','Ox','Tiger','Rabbit','Dragon','Snake','Horse','Goat','Monkey','Rooster','Dog','Pig'];
  return animals[(year - 4) % 12];
}

function getFriendZodiacs(animal) {
  var friends = {
    'Rat': ['Dragon','Monkey'],
    'Ox': ['Snake','Rooster'],
    'Tiger': ['Horse','Dog'],
    'Rabbit': ['Goat','Pig'],
    'Dragon': ['Rat','Monkey'],
    'Snake': ['Ox','Rooster'],
    'Horse': ['Tiger','Dog'],
    'Goat': ['Rabbit','Pig'],
    'Monkey': ['Rat','Dragon'],
    'Rooster': ['Ox','Snake'],
    'Dog': ['Tiger','Horse'],
    'Pig': ['Rabbit','Goat']
  };
  return friends[animal] || [];
}

function getFavDirection(lifePath) {
  var dirs = {1:'North',2:'Southwest',3:'East',4:'Southeast',5:'Center',6:'Northwest',7:'West',8:'Northeast',9:'South',11:'North',22:'Northeast',33:'South'};
  return dirs[lifePath] || 'East';
}

/* ══ Main finder ══ */
function findMyPlaces() {
  var dob     = document.getElementById('nb-dob').value;
  var year    = parseInt(document.getElementById('nb-year').value);
  var climate = document.getElementById('nb-climate').value;
  var environ = document.getElementById('nb-environ').value;
  var budget  = document.getElementById('nb-budget').value;
  var timing  = document.getElementById('nb-timing').value;
  var priority= document.getElementById('nb-priority').value;
  var abroad  = document.getElementById('nb-abroad').value;
  var country = document.getElementById('nb-country').value;

  if (!dob || !year) {
    alert('Please fill in your date of birth and birth year on Step 1 first.');
    switchTab('profile'); return;
  }

  var btn = document.getElementById('findPlacesBtn');
  btn.disabled = true; btn.textContent = 'Reading the stars... ✦';

  var digits = dob.replace(/-/g,'').split('').map(Number);
  var sum = digits.reduce(function(a,b){return a+b;},0);
  function reduce(n) {
    if (n === 11 || n === 22 || n === 33) return n;
    if (n < 10) return n;
    return reduce(String(n).split('').reduce(function(a,b){return a+Number(b);},0));
  }
  var lifePath   = reduce(sum);
  var zodiac     = getZodiac(year);
  var friends    = getFriendZodiacs(zodiac);
  var direction  = getFavDirection(lifePath);
  var currentYear = new Date().getFullYear();
  var personalYear = reduce(reduce(parseInt(dob.split('-')[2]) + parseInt(dob.split('-')[1]) + currentYear));

  var prompt = "You are a warm, knowledgeable numerology and Chinese astrology consultant helping someone find their ideal place to live. Be specific, warm and practical — not vague.\n\nThe person's details:\n- Life Path Number: " + lifePath + "\n- Chinese Zodiac: " + zodiac + " (friend signs: " + friends.join(', ') + ")\n- Favourable direction: " + direction + "\n- Personal Year Number (current): " + personalYear + "\n- Climate preference: " + climate + "\n- Environment: " + environ + "\n- Budget: " + budget + "\n- Open to moving abroad: " + abroad + "\n- Current country: " + country + "\n- Priority in new home: " + priority + "\n- Timing feeling: " + timing + "\n\nProvide:\n1. A brief (3-4 sentence) reading of their numerology + zodiac for relocation — warm and specific\n2. Whether " + currentYear + " (Personal Year " + personalYear + ") is a favourable year to move for them\n3. Their ideal address number (based on life path)\n4. Then list exactly 3 specific REAL cities or towns that match their profile. For each give: city name, country, why numerologically/astrologically aligned, one sentence on climate/lifestyle match. Format each city as: CITY NAME | COUNTRY | Numerology reason | Lifestyle note\n\nBe warm and specific. No generic advice. Make them feel seen.";

  fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      messages: [{ role: 'user', content: prompt }]
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    btn.disabled = false; btn.textContent = 'Find My Places ✦';
    var reply = (data.content && data.content[0]) ? data.content[0].text : 'Something got lost in translation — try again.';

    // Parse city blocks out
    var lines = reply.split('\n');
    var cityLines = lines.filter(function(l) { return l.includes('|') && l.split('|').length >= 3; });
    var narrative = reply;

    // Remove city lines from narrative for cleaner display
    cityLines.forEach(function(cl) { narrative = narrative.replace(cl, ''); });
    narrative = narrative.replace(/\n{3,}/g, '\n\n').trim();

    document.getElementById('nb-text').textContent = narrative;

    var citiesEl = document.getElementById('nb-cities');
    citiesEl.innerHTML = '';
    cityLines.forEach(function(cl) {
      var parts = cl.split('|').map(function(s) { return s.trim(); });
      var cityName    = parts[0] || '';
      var cityCountry = parts[1] || '';
      var numReason   = parts[2] || '';
      var lifeNote    = parts[3] || '';

      // Build Zillow / Property24 search URL
      var searchQuery = encodeURIComponent(cityName + ', ' + cityCountry);
      var propLink = (country === 'ZA')
        ? 'https://www.property24.com/property-for-sale/' + cityName.toLowerCase().replace(/\s+/g,'-')
        : 'https://www.zillow.com/homes/' + searchQuery + '_rb/';

      var card = document.createElement('div');
      card.className = 'll-num-city';
      card.innerHTML = '<div class="ll-num-city-name">' + cityName + '</div>' +
        '<div class="ll-num-city-detail">' + cityCountry + '</div>' +
        '<div class="ll-num-city-detail" style="margin-top:0.35rem;">' + numReason + '</div>' +
        '<div class="ll-num-city-detail" style="margin-top:0.25rem;font-style:italic;">' + lifeNote + '</div>' +
        '<a href="' + propLink + '" target="_blank" rel="noopener" class="ll-num-city-link">Browse Properties →</a>';
      citiesEl.appendChild(card);
    });

    switchTab('results');
  })
  .catch(function() {
    btn.disabled = false; btn.textContent = 'Find My Places ✦';
    document.getElementById('nb-text').textContent = 'Something got lost in the stars — check your connection and try again.';
    switchTab('results');
  });
}
</script>
