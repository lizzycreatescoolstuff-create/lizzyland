  </div>
</section>

<!-- ══════════════════════════════════════════
     SECTION 3: WHERE SHOULD YOU LIVE — NUMEROLOGY BOT
══════════════════════════════════════════ -->
<section class="ll-sol-section dark">
  <div class="ll-sol-narrow">
    <div class="ll-sol-header center">
      <div class="ll-sol-eyebrow light">✦ When somewhere feels wrong ✦</div>
      <h2 class="ll-sol-title light">Where Should You Live?</h2>
      <p class="ll-sol-tagline light">
        Your birth numbers, Chinese zodiac, favourable direction and climate — all matched to real cities and real properties. Not guesswork. Cosmic alignment.
      </p>
    </div>

    <div class="ll-num-bot">
      <div class="ll-num-bot-tabs">
        <button class="ll-num-tab active" onclick="switchTab('profile')">1. Your Profile</button>
        <button class="ll-num-tab" onclick="switchTab('prefs')">2. Preferences</button>
        <button class="ll-num-tab" onclick="switchTab('results')" id="resultsTab">3. Your Places</button>
      </div>

      <!-- TAB 1: Profile -->
      <div class="ll-num-panel active" id="panel-profile">
        <div class="ll-num-field">
          <label>Date of birth</label>
          <input type="date" id="nb-dob" oninput="calcLifePath()">
          <small id="nb-lifepath-preview"></small>
        </div>
        <div class="ll-num-field-row">
          <div class="ll-num-field">
            <label>Birth year (for Chinese zodiac)</label>
            <input type="number" id="nb-year" placeholder="e.g. 1983" min="1900" max="2010">
          </div>
          <div class="ll-num-field">
            <label>Current country</label>
            <select id="nb-country">
              <option value="">Select...</option>
              <option value="ZA">South Africa</option>
              <option value="US">United States</option>
              <option value="UK">United Kingdom</option>
              <option value="AU">Australia</option>
              <option value="PT">Portugal</option>
              <option value="ES">Spain</option>
              <option value="IT">Italy</option>
              <option value="NZ">New Zealand</option>
              <option value="OTHER">Other</option>
            </select>
          </div>
        </div>
        <div class="ll-num-field">
          <label>Are you open to moving abroad?</label>
          <select id="nb-abroad">
            <option value="local">No — within my country only</option>
            <option value="open">Yes — open to anything</option>
            <option value="specific">Yes — specific regions in mind</option>
          </select>
        </div>
        <button class="ll-num-run-btn" onclick="switchTab('prefs')">Next — Climate & Preferences →</button>
      </div>

      <!-- TAB 2: Preferences -->
      <div class="ll-num-panel" id="panel-prefs">
        <div class="ll-num-field-row">
          <div class="ll-num-field">
            <label>Preferred climate</label>
            <select id="nb-climate">
              <option value="tropical">Tropical / warm year-round</option>
              <option value="mediterranean">Mediterranean / mild &amp; sunny</option>
              <option value="coastal">Coastal / sea breeze</option>
              <option value="temperate">Temperate / four seasons</option>
              <option value="cool">Cool / mountain or highland</option>
            </select>
          </div>
          <div class="ll-num-field">
            <label>Environment feel</label>
            <select id="nb-environ">
              <option value="beach">Beach / ocean</option>
              <option value="bush">Bush / nature / wilderness</option>
              <option value="mountain">Mountain / elevated</option>
              <option value="city">Cosmopolitan city</option>
              <option value="rural">Rural / village</option>
            </select>
          </div>
        </div>
        <div class="ll-num-field-row">
          <div class="ll-num-field">
