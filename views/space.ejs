<%
  var pageTitle   = 'Wealth — Lizzyland';
  var pageDesc    = 'Your abundant life. Build something beautiful that fits your brain and your life.';
  var currentPage = 'wealth';
%>
<%- include('partials/header') %>

<style>
  /* ── Hero ── */
  .ll-w-hero {
    position: relative; min-height: 220px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; background: var(--warm-dark);
  }
  .ll-w-hero-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center 40%;
  }
  .ll-w-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(45,27,14,0.82) 0%, rgba(92,61,30,0.35) 55%, rgba(200,149,42,0.06) 100%);
  }
  .ll-w-hero-inner {
    position: relative; z-index: 2; max-width: 1100px; margin: 0 auto;
    width: 100%; padding: 2.5rem 2rem; color: var(--white); text-align: center;
  }
  .ll-w-hero-eyebrow {
    font-family: var(--font-accent); font-style: italic;
    font-size: 0.9rem; color: var(--gold-light);
    letter-spacing: 0.15em; opacity: 0.8; margin-bottom: 0.4rem;
  }
  .ll-w-hero-inner h1 {
    font-family: var(--font-display); font-size: clamp(2rem,5vw,3.2rem);
    color: var(--white); margin: 0 0 0.4rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .ll-w-hero-inner p {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.05rem; color: rgba(255,255,255,0.75); margin: 0;
  }

  /* ── Intro ── */
  .ll-w-intro { background: var(--sand-light); padding: 4.5rem 2rem; text-align: center; }
  .ll-w-intro-inner { max-width: 720px; margin: 0 auto; }
  .ll-w-eyebrow {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.2em; color: var(--gold); margin-bottom: 0.75rem;
  }
  .ll-w-intro h2 {
    font-family: var(--font-display); font-size: clamp(1.6rem,3.5vw,2.6rem);
    color: var(--warm-dark); margin-bottom: 1rem; font-weight: 600; line-height: 1.2;
  }
  .ll-w-lead {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.15rem; color: var(--text-soft); line-height: 1.85;
  }

  /* ── Shared section styles ── */
  .ll-w-section { padding: 5rem 2rem; }
  .ll-w-section.cream  { background: var(--cream); }
  .ll-w-section.sand   { background: var(--sand-light); }
  .ll-w-section.white  { background: var(--white); }
  .ll-w-section.teal   { background: linear-gradient(135deg, var(--ocean) 0%, #0d6b5e 100%); }
  .ll-w-section.dark   { background: linear-gradient(135deg, #1a1008 0%, #2d1b0e 100%); }

  .ll-w-section-inner  { max-width: 1100px; margin: 0 auto; }
  .ll-w-section-narrow { max-width: 820px; margin: 0 auto; }
  .ll-w-section-header { text-align: center; margin-bottom: 3rem; }

  .ll-w-section-eyebrow {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.22em; color: var(--gold); margin-bottom: 0.6rem;
  }
  .ll-w-section-eyebrow.light { color: var(--gold-light); opacity: 0.8; }
  .ll-w-section-title {
    font-family: var(--font-display); font-size: clamp(1.8rem,3.5vw,2.8rem);
    color: var(--warm-dark); font-weight: 600; line-height: 1.15; margin-bottom: 0.6rem;
  }
  .ll-w-section-title.light { color: var(--white); }
  .ll-w-section-tagline {
    font-family: var(--font-accent); font-style: italic;
    font-size: 1.1rem; color: var(--text-soft); line-height: 1.6;
  }
  .ll-w-section-tagline.light { color: rgba(255,255,255,0.7); }

  /* ── Ikigai Chatbot ── */
  .ll-ikigai-chat {
    background: var(--white); border-radius: var(--radius-md);
    box-shadow: 0 8px 40px rgba(0,0,0,0.1); overflow: hidden;
    max-width: 640px; margin: 0 auto;
  }
  .ll-chat-messages {
    padding: 1.5rem; min-height: 260px; max-height: 340px; overflow-y: auto;
    display: flex; flex-direction: column; gap: 0.85rem;
  }
  .ll-chat-bubble {
    max-width: 80%; padding: 0.75rem 1rem; border-radius: 18px; font-size: 0.9rem; line-height: 1.6;
  }
  .ll-chat-bubble.lizzy {
    background: var(--ocean); color: var(--white); align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .ll-chat-bubble.user {
    background: var(--sand-light); color: var(--warm-dark);
    align-self: flex-end; border-bottom-right-radius: 4px;
    border: 1px solid var(--sand-deep);
  }
  .ll-chat-bubble.lizzy.typing span {
    display: inline-block; width: 6px; height: 6px; border-radius: 50%;
    background: rgba(255,255,255,0.6); margin: 0 2px;
    animation: bounce 1.2s infinite;
  }
  .ll-chat-bubble.lizzy.typing span:nth-child(2) { animation-delay: 0.2s; }
  .ll-chat-bubble.lizzy.typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-6px)} }

  .ll-chat-input-row {
    display: flex; gap: 0.5rem; padding: 1rem 1.5rem;
    border-top: 1px solid var(--sand-deep); background: var(--sand-light);
  }
  .ll-chat-input {
    flex: 1; padding: 0.65rem 1rem; border-radius: 30px;
    border: 1.5px solid var(--sand-deep); background: var(--white);
    font-size: 0.9rem; font-family: var(--font-body); outline: none;
    transition: border-color 0.2s;
  }
  .ll-chat-input:focus { border-color: var(--ocean); }
  .ll-chat-send {
    padding: 0.65rem 1.25rem; background: var(--ocean); color: white;
    border: none; border-radius: 30px; font-weight: 600; font-size: 0.85rem;
    cursor: pointer; transition: background 0.2s;
  }
  .ll-chat-send:hover { background: var(--gold); }
  .ll-chat-note {
    text-align: center; margin-top: 1rem;
    font-size: 0.75rem; color: var(--text-muted); font-style: italic;
  }

  /* ── Two-column tools ── */
  .ll-tools-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    max-width: 1100px; margin: 0 auto;
  }
  .ll-tool-card {
    background: var(--white); border-radius: var(--radius-md);
    box-shadow: 0 4px 24px rgba(0,0,0,0.07); overflow: hidden;
    border: 1px solid var(--sand-deep);
  }
  .ll-tool-card-header {
    padding: 1.5rem 1.75rem 1rem;
    border-bottom: 1px solid var(--sand-deep);
    background: var(--sand-light);
  }
  .ll-tool-card-body { padding: 1.75rem; }

  /* numerology */
  .ll-num-result {
    display: none; margin-top: 1.25rem; padding: 1.25rem;
    background: linear-gradient(135deg, var(--ocean), #0d6b5e);
    border-radius: var(--radius-sm); color: white; text-align: center;
  }
  .ll-num-result.show { display: block; }
  .ll-num-number {
    font-family: var(--font-display); font-size: 3rem;
    color: var(--gold-light); line-height: 1; margin-bottom: 0.25rem;
  }
  .ll-num-name { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .ll-num-desc { font-size: 0.85rem; line-height: 1.7; opacity: 0.85; font-style: italic; }

  /* moving calculator */
  .ll-move-q { margin-bottom: 1rem; }
  .ll-move-q label {
    display: block; font-size: 0.85rem; color: var(--text-soft);
    font-weight: 600; margin-bottom: 0.35rem;
  }
  .ll-move-q select, .ll-move-q input[type=range] {
    width: 100%; padding: 0.5rem 0.75rem;
    border: 1.5px solid var(--sand-deep); border-radius: var(--radius-sm);
    font-size: 0.85rem; background: var(--sand-light); outline: none;
  }
  .ll-move-q input[type=range] { padding: 0; }
  .ll-move-score {
    display: none; margin-top: 1.25rem; padding: 1.25rem;
    border-radius: var(--radius-sm); text-align: center;
  }
  .ll-move-score.show { display: block; }
  .ll-move-score-num {
    font-family: var(--font-display); font-size: 2.5rem;
    line-height: 1; margin-bottom: 0.25rem;
  }
  .ll-tool-btn {
    width: 100%; padding: 0.7rem; background: var(--ocean); color: white;
    border: none; border-radius: 30px; font-weight: 600; font-size: 0.88rem;
    cursor: pointer; margin-top: 1rem; transition: background 0.2s;
  }
  .ll-tool-btn:hover { background: var(--gold); }

  /* ── Reading list / blog ── */
  .ll-reading-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 1.75rem;
    max-width: 1100px; margin: 0 auto 2.5rem;
  }
  .ll-book-card {
    background: var(--white); border-radius: var(--radius-md);
    padding: 1.75rem; border: 1px solid var(--sand-deep);
    box-shadow: 0 2px 16px rgba(0,0,0,0.05); transition: all 0.25s;
    position: relative; overflow: hidden;
  }
  .ll-book-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--ocean));
  }
  .ll-book-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
  .ll-book-emoji { font-size: 2rem; margin-bottom: 0.75rem; }
  .ll-book-title {
    font-family: var(--font-display); font-size: 1.1rem;
    color: var(--warm-dark); margin-bottom: 0.25rem; font-weight: 600;
  }
  .ll-book-author {
    font-size: 0.75rem; color: var(--gold); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.75rem;
  }
  .ll-book-synopsis {
    font-size: 0.85rem; color: var(--text-soft); line-height: 1.75;
    font-style: italic;
  }
  .ll-blog-cta-row { text-align: center; margin-top: 1rem; }

  /* ── Templates ── */
  .ll-templates-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 1.75rem;
    max-width: 1100px; margin: 0 auto;
  }
  .ll-template-card {
    background: var(--white); border-radius: var(--radius-md);
    padding: 2rem; border: 1px solid var(--sand-deep);
    box-shadow: 0 2px 16px rgba(0,0,0,0.05); transition: all 0.25s;
    text-align: center;
  }
  .ll-template-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
  .ll-template-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .ll-template-name {
    font-family: var(--font-display); font-size: 1.15rem;
    color: var(--warm-dark); margin-bottom: 0.5rem; font-weight: 600;
  }
  .ll-template-desc {
    font-size: 0.85rem; color: var(--text-soft); line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .ll-template-tag {
    display: inline-block; padding: 0.2rem 0.75rem;
    background: rgba(26,138,122,0.1); color: var(--ocean);
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; border-radius: 30px; margin-bottom: 1rem;
  }
  .ll-template-btn {
    display: inline-block; padding: 0.6rem 1.5rem;
    background: var(--ocean); color: white; border-radius: 30px;
    font-size: 0.82rem; font-weight: 600; text-decoration: none;
    transition: background 0.2s;
  }
  .ll-template-btn:hover { background: var(--gold); }
  .ll-template-btn.soon {
    background: var(--sand-deep); color: var(--text-muted); cursor: default;
  }
  .ll-template-btn.soon:hover { background: var(--sand-deep); }

  /* ── Shared CTA button ── */
  .ll-w-cta {
    display: inline-block; background: var(--ocean); color: var(--white) !important;
    padding: 0.8rem 2.2rem; border-radius: 50px; font-weight: 600; font-size: 0.9rem;
    letter-spacing: 0.04em; text-decoration: none; transition: background 0.2s, transform 0.2s;
  }
  .ll-w-cta:hover { background: var(--gold); transform: translateY(-2px); }
  .ll-w-cta.gold { background: var(--gold); color: var(--warm-dark) !important; }
  .ll-w-cta.gold:hover { background: var(--gold-light); }

  /* ── Philosophy / quote ── */
  .ll-w-philosophy { background: linear-gradient(135deg, var(--ocean) 0%, #0d6b5e 100%); padding: 3rem 2rem; }
  .ll-w-philosophy-inner { max-width: 620px; margin: 0 auto; text-align: center; }
  .ll-w-quote {
    font-family: var(--font-accent); font-style: italic;
    font-size: clamp(1.1rem,2.2vw,1.5rem); color: var(--white); line-height: 1.7; margin-bottom: 0.75rem;
  }
  .ll-w-byline { font-family: var(--font-display); font-size: 1rem; color: var(--gold-light); font-style: italic; }

  /* ── Back to doors ── */
  .ll-back-to-doors { padding: 2.5rem 2rem; background: var(--sand-light); }
  .ll-back-inner { max-width: 500px; margin: 0 auto; text-align: center; }
  .ll-back-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text-muted); margin-bottom: 1rem; }
  .ll-back-links { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .ll-back-link {
    display: inline-block; padding: 0.5rem 1.25rem; border-radius: 50px;
    background: var(--white); border: 2px solid var(--sand-deep);
    color: var(--text-soft); font-weight: 500; font-size: 0.85rem;
    text-decoration: none; transition: all 0.2s;
  }
  .ll-back-link:hover { border-color: var(--ocean); color: var(--ocean); }
  .ll-back-home { border-color: var(--gold); color: var(--gold); }
  .ll-back-home:hover { background: var(--gold); color: var(--white); }

  @media (max-width: 900px) {
    .ll-tools-grid, .ll-reading-grid, .ll-templates-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .ll-reading-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- ══ HERO ══ -->
<section class="ll-w-hero">
  <img src="/images/space-banner.jpg" alt="Wealth — Your Abundant Life" class="ll-w-hero-img" onerror="this.style.display='none'">
  <div class="ll-w-hero-overlay"></div>
  <div class="ll-w-hero-inner">
    <div class="ll-w-hero-eyebrow">✦ Door Two · Wealth ✦</div>
    <h1>Your Abundant Life.</h1>
    <p>Not hustle. Not excess. Purpose. Creativity. Joy. Built around your beautiful brain.</p>
  </div>
</section>

<!-- ══ INTRO ══ -->
<section class="ll-w-intro">
  <div class="ll-w-intro-inner">
    <div class="ll-w-eyebrow">What wealth actually means</div>
    <h2>La dolce vita is not a reward.<br>It's a decision.</h2>
    <p class="ll-w-lead">
      Most people spend their whole lives waiting for permission to live beautifully.
      I'm not interested in waiting. Wealth isn't the number in the bank —
      it's waking up and doing work that lights you up, in a life that actually fits you.
      Here's what I've found. Here's what works. Start wherever you are.
    </p>
  </div>
</section>

<!-- ══ IKIGAI CHATBOT ══ -->
<section class="ll-w-section teal">
  <div class="ll-w-section-narrow">
    <div class="ll-w-section-header">
      <div class="ll-w-section-eyebrow light">✦ Find Your Why ✦</div>
      <h2 class="ll-w-section-title light">The Ikigai Finder</h2>
      <p class="ll-w-section-tagline light">
        A gentle conversation. Not a quiz. Not a test.<br>
        Just a few questions to help you find what you're actually here to do.
      </p>
    </div>
    <div class="ll-ikigai-chat">
      <div class="ll-chat-messages" id="chatMessages">
        <div class="ll-chat-bubble lizzy">
          Hey! I'm so glad you're here. 🌿 Let's find your ikigai — the thing that sits at the crossroads of what you love, what you're good at, what the world needs, and what can sustain you. Ready? Tell me — what's something you do where time just disappears?
        </div>
      </div>
      <div class="ll-chat-input-row">
        <input class="ll-chat-input" id="chatInput" type="text" placeholder="Type your answer..." autocomplete="off">
        <button class="ll-chat-send" onclick="sendChat()">Send →</button>
      </div>
    </div>
    <p class="ll-chat-note">Powered by AI · Your conversation is private · No account needed</p>
  </div>
</section>

<!-- ══ TOOLS: NUMEROLOGY + MOVING ══ -->
<section class="ll-w-section sand">
  <div class="ll-w-section-inner">
    <div class="ll-w-section-header">
      <div class="ll-w-section-eyebrow">Tools for the journey</div>
      <h2 class="ll-w-section-title">A little clarity goes a long way.</h2>
      <p class="ll-w-section-tagline">Two tools I keep coming back to. Use them, share them, trust the numbers.</p>
    </div>
    <div class="ll-tools-grid">

      <!-- NUMEROLOGY -->
      <div class="ll-tool-card">
        <div class="ll-tool-card-header">
          <div class="ll-w-section-eyebrow">✦ Life Path</div>
          <h3 style="font-family:var(--font-display);font-size:1.4rem;color:var(--warm-dark);margin:0.25rem 0 0.35rem;">Numerology Calculator</h3>
          <p style="font-size:0.85rem;color:var(--text-muted);font-style:italic;margin:0;">Your life path number reveals the energy you came in with.</p>
        </div>
        <div class="ll-tool-card-body">
          <div class="ll-move-q">
            <label>Your date of birth</label>
            <input type="date" id="numDate" style="width:100%;padding:0.5rem 0.75rem;border:1.5px solid var(--sand-deep);border-radius:var(--radius-sm);font-size:0.9rem;background:var(--sand-light);outline:none;">
          </div>
          <button class="ll-tool-btn" onclick="calcNumerology()">Calculate My Number →</button>
          <div class="ll-num-result" id="numResult">
            <div class="ll-num-number" id="numNumber"></div>
            <div class="ll-num-name" id="numName"></div>
            <div class="ll-num-desc" id="numDesc"></div>
          </div>
        </div>
      </div>

      <!-- MOVING CALCULATOR -->
      <div class="ll-tool-card">
        <div class="ll-tool-card-header">
          <div class="ll-w-section-eyebrow">✦ Readiness Check</div>
          <h3 style="font-family:var(--font-display);font-size:1.4rem;color:var(--warm-dark);margin:0.25rem 0 0.35rem;">Should I Move?</h3>
          <p style="font-size:0.85rem;color:var(--text-muted);font-style:italic;margin:0;">A practical gut-check for one of life's biggest decisions.</p>
        </div>
        <div class="ll-tool-card-body">
          <div class="ll-move-q">
            <label>How happy are you where you live? (1 = miserable, 5 = love it)</label>
            <input type="range" id="moveQ1" min="1" max="5" value="3" oninput="document.getElementById('mq1val').innerText=this.value">
            <span style="font-size:0.8rem;color:var(--text-muted);">Current: <span id="mq1val">3</span></span>
          </div>
          <div class="ll-move-q">
            <label>How strong is your reason to move?</label>
            <select id="moveQ2">
              <option value="1">Vague feeling</option>
              <option value="2">A few real reasons</option>
              <option value="3" selected>Several clear reasons</option>
              <option value="4">Overwhelming need</option>
              <option value="5">I've already decided, just nervous</option>
            </select>
          </div>
          <div class="ll-move-q">
            <label>Do you have somewhere specific in mind?</label>
            <select id="moveQ3">
              <option value="1">Not at all</option>
              <option value="2" selected>A few ideas</option>
              <option value="3">A shortlist</option>
              <option value="4">One clear place</option>
              <option value="5">Already researched and ready</option>
            </select>
          </div>
          <div class="ll-move-q">
            <label>Financial readiness</label>
            <select id="moveQ4">
              <option value="1">No funds, no plan</option>
              <option value="2">Minimal savings</option>
              <option value="3" selected>Some savings, could make it work</option>
              <option value="4">Comfortable cushion</option>
              <option value="5">Fully funded and ready</option>
            </select>
          </div>
          <button class="ll-tool-btn" onclick="calcMove()">Get My Readiness Score →</button>
          <div class="ll-move-score" id="moveResult">
            <div class="ll-move-score-num" id="moveScore"></div>
            <div style="font-size:0.95rem;font-weight:600;margin-bottom:0.4rem;" id="moveVerdict"></div>
            <div style="font-size:0.82rem;font-style:italic;line-height:1.7;" id="moveAdvice"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ══ READING LIST / BLOG ══ -->
<section class="ll-w-section cream">
  <div class="ll-w-section-inner">
    <div class="ll-w-section-header">
      <div class="ll-w-section-eyebrow">Reading List</div>
      <h2 class="ll-w-section-title">Books that changed things for me.</h2>
      <p class="ll-w-section-tagline">
        ADHD-friendly synopses. No academic summaries — just what it actually did.
      </p>
    </div>
    <div class="ll-reading-grid">
      <div class="ll-book-card">
        <div class="ll-book-emoji">🍋</div>
        <div class="ll-book-title">Ikigai</div>
        <div class="ll-book-author">Héctor García & Francesc Miralles</div>
        <div class="ll-book-synopsis">
          This is the book that gave me language for something I'd been feeling for years.
          The Japanese concept of ikigai — your reason for being — isn't grand or dramatic.
          It lives in small, daily things. It stopped me chasing a destination and helped me build a life instead.
        </div>
      </div>
      <div class="ll-book-card">
        <div class="ll-book-emoji">🚀</div>
        <div class="ll-book-title">The Big Leap</div>
        <div class="ll-book-author">Gay Hendricks</div>
        <div class="ll-book-synopsis">
          The concept of the "Upper Limit Problem" — the way we sabotage ourselves just as things start going well —
          was like reading my own diary. Every time I got close to something good, I'd find a way to mess it up.
          This book named the pattern. Once you see it, you can't unsee it.
        </div>
      </div>
