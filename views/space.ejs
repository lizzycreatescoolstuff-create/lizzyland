<script>
/* ── Ikigai Chatbot ── */
var chatHistory = [];
var chatStep = 0;

function sendChat() {
  var input = document.getElementById('chatInput');
  var msg = input.value.trim();
  if (!msg) return;
  input.value = '';

  var messages = document.getElementById('chatMessages');

  // Add user bubble
  var userBubble = document.createElement('div');
  userBubble.className = 'll-chat-bubble user';
  userBubble.textContent = msg;
  messages.appendChild(userBubble);

  // Typing indicator
  var typing = document.createElement('div');
  typing.className = 'll-chat-bubble lizzy typing';
  typing.innerHTML = '<span></span><span></span><span></span>';
  messages.appendChild(typing);
  messages.scrollTop = messages.scrollHeight;

  chatHistory.push({ role: 'user', content: msg });

  fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 300,
      system: "You are Lizzy — warm, wise, South African, creator of Lizzyland. You're guiding the user through finding their ikigai in a gentle chat conversation. Ask one thoughtful question at a time. Keep responses short (2-4 sentences max). After 5-6 exchanges, summarise their ikigai in a beautiful, poetic sentence. Be warm, specific, encouraging. Never generic. Never use bullet points.",
      messages: chatHistory
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    typing.remove();
    var reply = (data.content && data.content[0]) ? data.content[0].text : "I'm thinking... give me a moment. 🌿";
    var lBubble = document.createElement('div');
    lBubble.className = 'll-chat-bubble lizzy';
    lBubble.textContent = reply;
    messages.appendChild(lBubble);
    messages.scrollTop = messages.scrollHeight;
    chatHistory.push({ role: 'assistant', content: reply });
  })
  .catch(function() {
    typing.remove();
    var lBubble = document.createElement('div');
    lBubble.className = 'll-chat-bubble lizzy';
    lBubble.textContent = "Something got lost in the waves 🌊 — try again in a moment.";
    messages.appendChild(lBubble);
    messages.scrollTop = messages.scrollHeight;
  });
}

document.getElementById('chatInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') sendChat();
});

/* ── Numerology ── */
var numData = {
  1: { name: 'The Leader', desc: 'Independent, pioneering, original. You came in to forge your own path — not follow someone else\'s map. Your wealth comes from ownership and vision.' },
  2: { name: 'The Diplomat', desc: 'Intuitive, collaborative, deeply perceptive. You see what others miss. Your wealth comes from connection, harmony and the power of partnership.' },
  3: { name: 'The Creator', desc: 'Expressive, joyful, magnetic. You are here to create — words, art, ideas, beauty. Your wealth flows when you let yourself be truly seen.' },
  4: { name: 'The Builder', desc: 'Practical, disciplined, reliable. You build things that last. Your wealth comes through structure, consistency and the beauty of a plan well executed.' },
  5: { name: 'The Adventurer', desc: 'Freedom-loving, versatile, magnetic. You need variety like oxygen. Your wealth comes through adaptability and the courage to change direction.' },
  6: { name: 'The Nurturer', desc: 'Caring, responsible, artistic. You create beauty and hold spaces for others. Your wealth comes through service, beauty and community.' },
  7: { name: 'The Seeker', desc: 'Analytical, spiritual, deeply intelligent. You need truth. Your wealth comes through mastery, depth and the courage to trust your own knowing.' },
  8: { name: 'The Achiever', desc: 'Powerful, ambitious, magnetic. You are wired for abundance. Your wealth comes when you step fully into your authority without apology.' },
  9: { name: 'The Humanitarian', desc: 'Compassionate, wise, transformative. You are here for something bigger than yourself. Your wealth comes through giving your gifts fully to the world.' },
  11: { name: 'The Intuitive', desc: 'A master number. Highly sensitive, visionary, deeply spiritual. You are here to inspire on a large scale. Your wealth comes through trusting your extraordinary intuition.' },
  22: { name: 'The Master Builder', desc: 'A master number. You have the vision of an 11 and the practicality of a 4. You are capable of building things that change the world. No pressure. 😊' },
  33: { name: 'The Master Teacher', desc: 'The rarest master number. Pure compassion, wisdom and creative power. You are here to heal, teach and elevate. Your wealth is the love you generate.' }
};

function calcNumerology() {
  var d = document.getElementById('numDate').value;
  if (!d) { alert('Please enter your date of birth.'); return; }
  var digits = d.replace(/-/g,'').split('').map(Number);
  var sum = digits.reduce(function(a,b){return a+b;},0);
  function reduce(n) {
    if (n === 11 || n === 22 || n === 33) return n;
    if (n < 10) return n;
    return reduce(String(n).split('').reduce(function(a,b){return a+Number(b);},0));
  }
  var lp = reduce(sum);
  var data = numData[lp] || numData[9];
  document.getElementById('numNumber').textContent = lp;
  document.getElementById('numName').textContent = data.name;
  document.getElementById('numDesc').textContent = data.desc;
  var r = document.getElementById('numResult');
  r.className = 'll-num-result show';
}

/* ── Moving Calculator ── */
function calcMove() {
  var q1 = 6 - parseInt(document.getElementById('moveQ1').value); // invert — happy = don't move
  var q2 = parseInt(document.getElementById('moveQ2').value);
  var q3 = parseInt(document.getElementById('moveQ3').value);
  var q4 = parseInt(document.getElementById('moveQ4').value);
  var total = q1 + q2 + q3 + q4;
  var pct = Math.round((total / 20) * 100);

  var verdict, advice, bg;
  if (pct < 35) {
    verdict = 'Not yet. Stay and grow.';
    advice = 'The restlessness you\'re feeling is real, but the timing isn\'t quite there. Use this season to get clear on where you actually want to go — and to build the foundation that makes moving feel like freedom, not escape.';
    bg = '#e8ddd0';
  } else if (pct < 60) {
    verdict = 'You\'re getting warmer.';
    advice = 'The pull is real and some pieces are in place. What\'s missing? Is it clarity, finances, or just courage? Pick the one thing holding you back and work on that specifically. You\'re closer than you think.';
    bg = 'rgba(200,149,42,0.15)';
  } else if (pct < 80) {
    verdict = 'The signs are saying yes.';
    advice = 'Your readiness is genuinely high. The reasons are clear, you have a direction, and the practical pieces are mostly there. What would it take to make this real in the next 6 months? Start that list today.';
    bg = 'rgba(26,138,122,0.12)';
  } else {
    verdict = 'What are you waiting for? 🌴';
    advice = 'Everything is pointing the same direction. You know where you want to go, you have the means to get there, and staying is costing you more than moving. This isn\'t reckless — it\'s ready.';
    bg = 'rgba(26,138,122,0.2)';
  }

  var el = document.getElementById('moveResult');
  el.style.background = bg;
  document.getElementById('moveScore').textContent = pct + '%';
  document.getElementById('moveVerdict').textContent = verdict;
  document.getElementById('moveAdvice').textContent = advice;
  el.className = 'll-move-score show';
}
</script>
