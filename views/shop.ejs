<%
  var pageTitle   = 'Happiness — Lizzyland';
  var pageDesc    = 'Beautiful clothing, dream yacht charters and curated villa holidays.';
  var currentPage = 'shop';
%>
<%- include('partials/header') %>

<style>
/* ── Hero ── */
.ll-shop-hero {
  background: linear-gradient(135deg, #1a1008 0%, #2d1b08 50%, #1a0d08 100%);
  padding: 4rem 2rem 3rem; text-align: center; position: relative; overflow: hidden;
}
.ll-shop-hero::before {
  content:''; position:absolute; inset:0;
  background: radial-gradient(circle at 30% 50%, rgba(200,149,42,0.06) 0%, transparent 60%),
              radial-gradient(circle at 70% 30%, rgba(26,138,122,0.05) 0%, transparent 50%);
}
.ll-shop-hero-inner { position:relative; z-index:1; max-width:600px; margin:0 auto; }
.ll-shop-eyebrow { font-family: var(--font-accent); font-style:italic; color:var(--gold-light); font-size:0.95rem; letter-spacing:0.15em; opacity:0.8; }
.ll-shop-title { font-family: var(--font-heading); font-size: clamp(2rem,5vw,3.5rem); color:var(--white); margin:0.4rem 0 0.6rem; }
.ll-shop-sub { font-family:var(--font-accent); font-style:italic; color:rgba(255,255,255,0.55); font-size:1rem; }

/* ── Brand tabs ── */
.ll-brand-tabs {
  display:flex; justify-content:center; gap:0.75rem;
  padding:1.5rem 1rem; background:var(--warm-dark);
  border-bottom:1px solid rgba(200,149,42,0.15); flex-wrap:wrap;
}
.ll-brand-tab {
  padding:0.55rem 1.4rem; border-radius:30px; font-size:0.88rem; font-weight:600;
  text-decoration:none; border:1.5px solid rgba(200,149,42,0.3);
  color:rgba(255,255,255,0.55); transition:all 0.2s;
}
.ll-brand-tab:hover, .ll-brand-tab.active {
  background:var(--gold); border-color:var(--gold); color:#fff;
}

/* ── Product grid ── */
.ll-shop-grid-wrap { max-width:1300px; margin:0 auto; padding:3rem 1.5rem; background: var(--cream); }
.ll-shop-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:2rem; }
.ll-product-card {
  background:var(--sand-light); border-radius:var(--radius-lg);
  overflow:hidden; transition:transform 0.25s, box-shadow 0.25s;
  box-shadow:0 2px 12px rgba(45,27,14,0.08);
}
.ll-product-card:hover { transform:translateY(-4px); box-shadow:0 8px 32px rgba(45,27,14,0.15); }
.ll-product-img-wrap { aspect-ratio:4/5; overflow:hidden; background:#e8ddd0; }
.ll-product-img-wrap img { width:100%; height:100%; object-fit:cover; transition:transform 0.4s; }
.ll-product-card:hover .ll-product-img-wrap img { transform:scale(1.04); }
.ll-product-body { padding:1.1rem 1.25rem 1.4rem; }
.ll-product-brand { font-size:0.72rem; color:var(--gold); font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.3rem; }
.ll-product-name { font-family:var(--font-heading); font-size:1.1rem; color:var(--warm-dark); margin-bottom:0.5rem; line-height:1.2; }
.ll-product-price { font-weight:700; font-size:1rem; color:var(--warm-dark); }
.ll-product-cta {
  display:block; width:100%; margin-top:0.85rem; padding:0.6rem;
  background:var(--warm-dark); color:var(--white); border-radius:var(--radius-xl);
  text-align:center; font-weight:600; font-size:0.85rem; text-decoration:none;
  transition:background 0.2s;
}
.ll-product-cta:hover { background:var(--gold); }
.ll-shop-empty { text-align:center; padding:5rem 2rem; opacity:0.45; }
.ll-shop-empty-icon { font-size:3rem; margin-bottom:1rem; }
.ll-shop-empty-text { font-family:var(--font-accent); font-style:italic; font-size:1.1rem; color:var(--text-muted); }

/* ── Shared section styles ── */
.ll-h-section { padding: 5rem 2rem; }
.ll-h-section.sand  { background: var(--sand-light); }
.ll-h-section.cream { background: var(--cream); }
.ll-h-section.dark  { background: linear-gradient(160deg, #0a1628 0%, #0d2240 100%); }
.ll-h-section.teal  { background: linear-gradient(135deg, var(--ocean) 0%, #0d6b5e 100%); }

.ll-h-inner { max-width: 1100px; margin: 0 auto; }

/* ── Magazine split ── */
.ll-h-split {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 4.5rem; align-items: center; max-width: 1100px; margin: 0 auto;
}
.ll-h-split.reverse { direction: rtl; }
.ll-h-split.reverse > * { direction: ltr; }

.ll-h-split-img {
  width: 100%; border-radius: var(--radius-md);
  object-fit: cover; aspect-ratio: 3/4;
  display: block;
}
.ll-h-split.light .ll-h-split-img {
  box-shadow: 0 16px 56px rgba(0,0,0,0.15);
}
.ll-h-split.dark-img .ll-h-split-img {
  box-shadow: 0 16px 56px rgba(0,0,0,0.5);
}

.ll-h-eyebrow {
  font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.22em; color: var(--gold); margin-bottom: 0.75rem;
}
.ll-h-eyebrow.light { color: var(--gold-light); opacity: 0.85; }

.ll-h-title {
  font-family: var(--font-display); font-size: clamp(2rem,4vw,3rem);
  font-weight: 600; line-height: 1.1; margin-bottom: 0.5rem; color: var(--warm-dark);
}
.ll-h-title.light { color: var(--white); }

.ll-h-tagline {
  font-family: var(--font-accent); font-style: italic;
  font-size: 1.15rem; line-height: 1.55; margin-bottom: 1.5rem; color: var(--ocean);
}
.ll-h-tagline.light { color: rgba(255,255,255,0.7); }

.ll-h-desc {
  font-size: 0.97rem; color: var(--text-soft);
  line-height: 1.85; margin-bottom: 2rem;
}
.ll-h-desc.light { color: rgba(255,255,255,0.65); }

.ll-h-cta {
  display: inline-block; background: var(--ocean); color: var(--white) !important;
  padding: 0.85rem 2.25rem; border-radius: 50px; font-weight: 600; font-size: 0.9rem;
  text-decoration: none; transition: background 0.2s, transform 0.2s;
}
.ll-h-cta:hover { background: var(--gold); transform: translateY(-2px); }
.ll-h-cta.gold { background: var(--gold); color: var(--warm-dark) !important; }
.ll-h-cta.gold:hover { background: var(--gold-light); }
.ll-h-cta.outline {
  background: transparent; color: var(--white) !important;
  border: 1.5px solid rgba(255,255,255,0.5);
}
.ll-h-cta.outline:hover { background: rgba(255,255,255,0.1); transform: translateY(-2px); }

.ll-h-affiliate-note {
  display: block; margin-top: 0.75rem;
  font-size: 0.72rem; color: var(--text-muted); font-style: italic;
}
.ll-h-affiliate-note.light { color: rgba(255,255,255,0.35); }

/* ── Divider ── */
.ll-h-section-divider {
  text-align: center; padding: 1.5rem 0;
  font-size: 0.75rem; letter-spacing: 0.3em; color: var(--text-muted);
  background: var(--sand-light);
}

/* ── Back to doors ── */
.ll-back-to-doors { padding: 2.5rem 2rem; background: var(--sand-light); }
.ll-back-inner { max-width: 500px; margin: 0 auto; text-align: center; }
.ll-back-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text-muted); margin-bottom: 1rem; }
.ll-back-links { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
.ll-back-link {
  display: inline-block; padding: 0.5rem 1.25rem; border-radius: 50px;
  background: var(--white); border: 2px solid var(--sand-deep);
  color: var(--text-soft); font-weight: 500; font-size: 0.85rem;
  text-decoration: none; transition: all 0.2s;
}
.ll-back-link:hover { border-color: var(--ocean); color: var(--ocean); }
.ll-back-home { border-color: var(--gold); color: var(--gold); }
.ll-back-home:hover { background: var(--gold); color: var(--white); }

@media (max-width: 768px) {
  .ll-h-split { grid-template-columns: 1fr; gap: 2rem; }
  .ll-h-split.reverse { direction: ltr; }
  .ll-h-split-img { aspect-ratio: 16/9; }
  .ll-shop-grid { grid-template-columns: repeat(2,1fr); gap: 1rem; }
  .ll-shop-grid-wrap { padding: 2rem 1rem; }
}
@media (max-width: 480px) {
  .ll-shop-grid { grid-template-columns: 1fr; }
}
</style>

<!-- ══ HERO ══ -->
<section class="ll-shop-hero">
  <div class="ll-shop-hero-inner">
    <p class="ll-shop-eyebrow">✦ Door Three · Joy ✦</p>
    <h1 class="ll-shop-title">Happiness</h1>
    <p class="ll-shop-sub">Beautiful things. Dream escapes. The life you actually want.</p>
  </div>
</section>

<!-- ══ BRAND TABS ══ -->
<div class="ll-brand-tabs">
  <a href="/shop" class="ll-brand-tab <%= currentBrand === 'all' ? 'active' : '' %>">All</a>
  <a href="/shop?brand=selva-mar" class="ll-brand-tab <%= currentBrand === 'selva-mar' ? 'active' : '' %>">🌿 Selva Mar</a>
  <a href="/shop?brand=meridian"  class="ll-brand-tab <%= currentBrand === 'meridian'  ? 'active' : '' %>">⚓ Meridian</a>
</div>

<!-- ══ CLOTHING GRID ══ -->
<div class="ll-shop-grid-wrap">
  <% if (typeof products !== 'undefined' && products && products.length > 0) { %>
    <div class="ll-shop-grid">
      <% products.forEach(function(p) { %>
      <div class="ll-product-card">
        <div class="ll-product-img-wrap">
          <% if (p.image_url) { %>
            <img src="<%= p.image_url %>" alt="<%= p.name %>" loading="lazy">
          <% } else { %>
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;opacity:0.3;">🌴</div>
          <% } %>
        </div>
        <div class="ll-product-body">
          <div class="ll-product-brand"><%= p.brand || 'Lizzyland' %></div>
          <div class="ll-product-name"><%= p.name %></div>
          <div class="ll-product-price">R<%= p.price ? Number(p.price).toFixed(2) : '—' %></div>
          <a href="<%= p.buy_url || '#' %>" class="ll-product-cta" target="<%= p.buy_url ? '_blank' : '_self' %>">Shop Now →</a>
        </div>
      </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="ll-shop-empty">
      <div class="ll-shop-empty-icon">🌴</div>
      <p class="ll-shop-empty-text">Beautiful things coming soon...</p>
      <p style="font-size:0.85rem;opacity:0.5;margin-top:0.5rem;">Check back shortly — Selva Mar is almost here.</p>
    </div>
  <% } %>
</div>

<!-- ══ DIVIDER ══ -->
<div class="ll-h-section-divider">✦ · ✦ · ✦</div>

<!-- ══ SAIL AWAY — YACHTS ══ -->
<section class="ll-h-section dark">
  <div class="ll-h-split dark-img">
    <img src="/images/yacht-hero.jpg" alt="Sail Away — Yacht Charters" class="ll-h-split-img"
      onerror="this.style.cssText='width:100%;aspect-ratio:3/4;background:linear-gradient(160deg,#0d1f3c,#1a3a6b);border-radius:var(--radius-md);display:block;'">
    <div>
      <div class="ll-h-eyebrow light">✦ Sail Away ✦</div>
      <h2 class="ll-h-title light">Charter your<br>own piece of sea.</h2>
      <p class="ll-h-tagline light">Not a cruise. Not a resort. Your own vessel, your own pace, your own horizon.</p>
      <p class="ll-h-desc light">
        There is something that happens when the land disappears behind you.
        The noise stops. The to-do list becomes irrelevant. The only agenda is the wind.
        Yacht charters are not as out of reach as you think — from bareboat sailing holidays
        to fully crewed superyachts, there's an ocean of options.
        I've done the research so you can simply choose your sea.
      </p>
      <a href="/yachts" class="ll-h-cta gold">Explore Yacht Charters →</a>
      <span class="ll-h-affiliate-note light">Curated affiliate links — I earn a commission at no extra cost to you.</span>
    </div>
  </div>
</section>

<!-- ══ EXPAND YOUR HORIZONS — VILLAS ══ -->
<section class="ll-h-section teal">
  <div class="ll-h-split reverse">
    <img src="/images/villa-hero.jpg" alt="Expand Your Horizons — Villa Holidays" class="ll-h-split-img"
      onerror="this.style.cssText='width:100%;aspect-ratio:3/4;background:linear-gradient(160deg,#0d6b5e,#1a8a7a);border-radius:var(--radius-md);display:block;'">
    <div>
      <div class="ll-h-eyebrow light">✦ Expand Your Horizons ✦</div>
      <h2 class="ll-h-title light">A villa that<br>remembers your name.</h2>
      <p class="ll-h-tagline light">Not a hotel room. Not a resort. A home — just an extraordinarily beautiful one.</p>
      <p class="ll-h-desc light">
        The best holidays I've ever had were in private villas. Your own pool. Your own kitchen.
        Your own pace. No check-out time breathing down your neck.
        I curate only from the top 3% of properties globally — Plum Guide's standard,
        not mine (though mine are stricter). Tuscany, the Greek islands, Bali, South Africa.
        The world is full of extraordinary places to arrive and exhale.
      </p>
      <a href="/villas" class="ll-h-cta outline">Explore Dream Villas →</a>
      <span class="ll-h-affiliate-note light">Curated affiliate links — I earn a commission at no extra cost to you.</span>
    </div>
  </div>
</section>

<!-- ══ BACK TO DOORS ══ -->
<section class="ll-back-to-doors">
  <div class="ll-back-inner">
    <p class="ll-back-label">Explore the other doors</p>
    <div class="ll-back-links">
      <a href="/health" class="ll-back-link">Health</a>
      <a href="/space"  class="ll-back-link">Wealth</a>
      <a href="/"       class="ll-back-link ll-back-home">← Lizzyland</a>
    </div>
  </div>
</section>

<div class="ll-divider">✦ · ✦ · ✦</div>

<%- include('partials/footer') %>
