<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Lizzyland — La Dolce Vita' %></title>
  <meta name="description" content="<%= typeof pageDesc !== 'undefined' ? pageDesc : 'Lizzyland — your tropical gateway to Health, Wealth and Happiness.' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Oleo+Script:wght@400;700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Cormorant+Garamond:ital,wght@1,400;1,600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/lizzyland.css">
  <meta name="impact-site-verification" value="02f5caca-9929-492d-8845-e8649e19820a">
</head>
<body>

  <!-- ══ HEADER ══ -->
  <header class="ll-header">
    <div class="ll-header-inner">

      <a href="/" class="ll-logo">
        <img src="/images/lizzyland-logo.png" alt="Lizzyland" class="ll-logo-img" onerror="this.style.display='none'">
        <span class="ll-logo-text">Lizzy<span>land</span></span>
      </a>

      <!-- Mobile hamburger -->
      <button class="ll-nav-toggle" id="navToggle" aria-label="Open menu">☰</button>

      <nav class="ll-nav-wrap" id="navWrap">
        <ul class="ll-nav">
          <li><a href="/"       class="<%= typeof currentPage !== 'undefined' && currentPage === 'home'     ? 'active' : '' %>">Home</a></li>
          <li><a href="/health" class="<%= typeof currentPage !== 'undefined' && currentPage === 'health'   ? 'active' : '' %>">Health</a></li>
          <li><a href="/space"  class="<%= typeof currentPage !== 'undefined' && currentPage === 'space'    ? 'active' : '' %>">Wealth</a></li>
          <li><a href="/shop"   class="<%= typeof currentPage !== 'undefined' && currentPage === 'shop'     ? 'active' : '' %>">Happiness</a></li>
          <li><a href="/blog"   class="<%= typeof currentPage !== 'undefined' && currentPage === 'blog'     ? 'active' : '' %>">Blog</a></li>
          <li><a href="/about"  class="<%= typeof currentPage !== 'undefined' && currentPage === 'about'    ? 'active' : '' %>">About</a></li>
        </ul>
        <a href="/shop" class="ll-nav-cta">Shop</a>
        <!-- Admin lock — tiny, only Lizzy knows it's there -->
        <a href="/admin" class="ll-admin-lock" title="Admin" aria-label="Admin">🔒</a>
      </nav>

    </div>
  </header>

  <style>
    .ll-admin-lock {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      font-size: 0.9rem;
      opacity: 0.25;
      transition: opacity 0.2s;
      text-decoration: none;
      border-radius: 50%;
      margin-left: 0.5rem;
    }
    .ll-admin-lock:hover { opacity: 0.8; }
  </style>

  <script>
    var toggle = document.getElementById('navToggle');
    var nav    = document.getElementById('navWrap');
    if (toggle && nav) {
      toggle.addEventListener('click', function() {
        nav.classList.toggle('open');
        toggle.textContent = nav.classList.contains('open') ? '✕' : '☰';
      });
    }
  </script>
