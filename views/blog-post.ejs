<% var pageTitle = (typeof post !== 'undefined' && post) ? post.title + ' — Lizzyland' : 'Lizzyland Journal'; var currentPage = 'blog'; %>
<%- include('partials/header') %>
<style>
.ll-post-wrap { max-width:740px; margin:0 auto; padding:3rem 1.5rem 5rem; }
.ll-post-cat { font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--gold); margin-bottom:0.75rem; }
.ll-post-title { font-family:var(--font-display); font-size:clamp(1.8rem,4vw,2.8rem); color:var(--warm-dark); margin-bottom:0.5rem; line-height:1.15; }
.ll-post-date { font-family:var(--font-accent); font-style:italic; color:var(--text-muted); font-size:0.9rem; margin-bottom:2rem; }
.ll-post-image { width:100%; border-radius:var(--radius-lg); margin-bottom:2rem; max-height:460px; object-fit:cover; }
.ll-post-body { font-size:1rem; line-height:1.85; color:var(--text-body); }
.ll-post-body p { margin-bottom:1.25rem; }
.ll-post-back { display:inline-block; margin-top:3rem; color:var(--gold); font-weight:600; text-decoration:none; font-size:0.9rem; }
.ll-post-back:hover { text-decoration:underline; }
</style>
<div class="ll-post-wrap">
  <% if (typeof post !== 'undefined' && post) { %>
    <div class="ll-post-cat"><%= post.category || 'general' %></div>
    <h1 class="ll-post-title"><%= post.title %></h1>
    <div class="ll-post-date"><%= post.created_at ? new Date(post.created_at).toLocaleDateString('en-ZA',{day:'numeric',month:'long',year:'numeric'}) : '' %></div>
    <% if (post.image_url) { %><img src="<%= post.image_url %>" class="ll-post-image" alt="<%= post.title %>"><% } %>
    <div class="ll-post-body">
      <%- (post.body || '').replace(/\n/g,'<br>') %>
    </div>
    <a href="/blog" class="ll-post-back">← Back to the journal</a>
  <% } %>
</div>
<%- include('partials/footer') %>
