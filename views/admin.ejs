<%
  var pageTitle   = 'Admin Dashboard — Lizzyland';
  var currentPage = 'admin';
%>
<%- include('partials/header') %>

<style>
/* ═══════════════════════════════════════
   LIZZYLAND ADMIN — Superpowered Dark
═══════════════════════════════════════ */
* { box-sizing: border-box; }
body { background: #090f0d; }

.ll-admin-wrap { max-width: 1400px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }

/* ── Topbar ── */
.ll-admin-topbar {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.75rem;
}
.ll-admin-title {
  font-family: 'Oleo Script', cursive; font-size: 1.8rem;
  color: var(--gold, #c8952a); margin: 0;
}
.ll-admin-meta { font-size: 0.8rem; color: rgba(255,255,255,0.4); margin-top: 0.1rem; }

/* ── Tab bar ── */
.ll-admin-tabs {
  display: flex; gap: 3px;
  border-bottom: 2px solid rgba(200,149,42,0.25);
  margin-bottom: 1.5rem; overflow-x: auto;
  padding-bottom: 0; -webkit-overflow-scrolling: touch;
}
.ll-admin-tab {
  padding: 0.65rem 1.1rem;
  background: rgba(255,255,255,0.03);
  color: rgba(255,255,255,0.45);
  border: none; border-radius: 8px 8px 0 0;
  font-weight: 600; font-size: 0.85rem; cursor: pointer;
  white-space: nowrap; transition: all 0.2s;
  border-bottom: 2px solid transparent;
}
.ll-admin-tab:hover  { background: rgba(200,149,42,0.08); color: var(--gold, #c8952a); }
.ll-admin-tab.active { background: rgba(200,149,42,0.12); color: var(--gold, #c8952a); border-bottom: 2px solid var(--gold, #c8952a); }

/* ── Tab content ── */
.ll-tab-content { display: none; }
.ll-tab-content.active { display: block; }

/* ── Stat cards ── */
.ll-stat-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem; margin-bottom: 1.5rem;
}
.ll-stat-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(200,149,42,0.2);
  border-radius: 10px; padding: 1rem 1.1rem;
}
.ll-stat-val {
  font-family: 'Playfair Display', serif; font-size: 1.9rem;
  font-weight: 700; color: var(--gold, #c8952a); line-height: 1;
}
.ll-stat-lbl {
  font-size: 0.72rem; color: rgba(255,255,255,0.4);
  text-transform: uppercase; letter-spacing: 0.07em; margin-top: 0.3rem;
}
.ll-stat-sub { font-size: 0.7rem; color: rgba(200,149,42,0.5); margin-top: 0.15rem; }

/* ── Sparkline ── */
.ll-sparkline-wrap {
  display: flex; align-items: flex-end; gap: 4px;
  height: 36px; margin-top: 0.5rem;
}
.ll-spark-bar {
  flex: 1; border-radius: 3px 3px 0 0;
  background: linear-gradient(to top, rgba(200,149,42,0.7), rgba(232,184,75,0.9));
  min-height: 2px; transition: height 0.3s;
  cursor: pointer; position: relative;
}
.ll-spark-bar:hover { background: linear-gradient(to top, #c8952a, #e8b84b); }

/* ── Section box ── */
.ll-admin-box {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(200,149,42,0.18);
  border-radius: 12px; padding: 1.25rem; margin-bottom: 1.25rem;
}
.ll-admin-box-title {
  font-family: 'Playfair Display', serif;
  color: var(--gold, #c8952a); font-size: 0.95rem;
  margin: 0 0 1.1rem; padding-bottom: 0.65rem;
  border-bottom: 1px solid rgba(200,149,42,0.15);
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 0.5rem;
}

/* ── Tables ── */
.ll-admin-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.ll-admin-table th {
  color: rgba(200,149,42,0.75); font-weight: 600; text-align: left;
  padding: 0.5rem 0.65rem; border-bottom: 1px solid rgba(200,149,42,0.15);
  font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em;
}
.ll-admin-table td {
  padding: 0.6rem 0.65rem; color: rgba(255,255,255,0.8);
  border-bottom: 1px solid rgba(255,255,255,0.05); vertical-align: middle;
}
.ll-admin-table tr:last-child td { border-bottom: none; }
.ll-admin-table tr:hover td { background: rgba(200,149,42,0.04); }

/* ── Buttons ── */
.ll-btn {
  padding: 0.4rem 0.85rem; border-radius: 6px; font-size: 0.8rem;
  font-weight: 600; cursor: pointer; border: none; transition: all 0.2s;
  text-decoration: none; display: inline-block; font-family: inherit;
}
.ll-btn-gold   { background: var(--gold, #c8952a); color: #fff; }
.ll-btn-teal   { background: var(--ocean, #1a8a7a); color: #fff; }
.ll-btn-danger { background: rgba(220,60,60,0.8); color: #fff; }
.ll-btn-ghost  { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.65); }
.ll-btn-green  { background: rgba(65,220,20,0.8); color: #fff; }
.ll-btn:hover  { opacity: 0.82; transform: translateY(-1px); }

.ll-btn-primary {
  background: var(--gold, #c8952a); color: #fff;
  padding: 0.6rem 1.3rem; border-radius: 8px;
  font-weight: 700; font-size: 0.88rem;
  cursor: pointer; border: none; transition: all 0.2s; font-family: inherit;
}
.ll-btn-primary:hover { opacity: 0.85; }

/* ── Forms ── */
.ll-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
.ll-form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.9rem; }
.ll-form-group { margin-bottom: 0.9rem; }
.ll-form-group label {
  display: block; font-size: 0.75rem; color: rgba(200,149,42,0.8);
  margin-bottom: 0.3rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
}
.ll-form-group input,
.ll-form-group select,
.ll-form-group textarea {
  width: 100%; padding: 0.6rem 0.85rem;
  background: rgba(255,255,255,0.06); border: 1px solid rgba(200,149,42,0.25);
  border-radius: 8px; color: rgba(255,255,255,0.9);
  font-size: 0.88rem; font-family: 'DM Sans', sans-serif; box-sizing: border-box;
}
.ll-form-group input:focus,
.ll-form-group select:focus,
.ll-form-group textarea:focus {
  outline: none; border-color: var(--gold, #c8952a); background: rgba(200,149,42,0.07);
}
.ll-form-group select option { background: #111e18; }
.ll-form-group textarea { resize: vertical; min-height: 100px; }

/* ── Badge ── */
.ll-badge {
  display: inline-block; padding: 0.18rem 0.55rem;
  border-radius: 20px; font-size: 0.7rem; font-weight: 700;
}
.ll-badge-green  { background: rgba(65,220,20,0.12);  color: #5adc28; }
.ll-badge-gold   { background: rgba(200,149,42,0.18);  color: #c8952a; }
.ll-badge-blue   { background: rgba(26,138,122,0.18);  color: #28b89e; }
.ll-badge-red    { background: rgba(220,60,60,0.12);   color: #f06060; }
.ll-badge-purple { background: rgba(120,80,200,0.18);  color: #a888e8; }

/* ── Search ── */
.ll-search {
  width: 100%; max-width: 360px; padding: 0.55rem 0.9rem;
  background: rgba(255,255,255,0.05); border: 1px solid rgba(200,149,42,0.2);
  border-radius: 8px; color: rgba(255,255,255,0.8); font-size: 0.85rem;
  margin-bottom: 0.9rem; font-family: inherit;
}

/* ── Modal ── */
.ll-modal {
  display: none; position: fixed; inset: 0; z-index: 2000;
  background: rgba(0,0,0,0.88); overflow-y: auto; padding: 2rem 1rem;
}
.ll-modal-box {
  background: #0d2420; border: 1px solid rgba(200,149,42,0.3);
  border-radius: 14px; padding: 2rem; max-width: 640px;
  margin: 0 auto; position: relative;
}
.ll-modal-title {
  font-family: 'Oleo Script', cursive; font-size: 1.4rem;
  color: var(--gold, #c8952a); margin: 0 0 1.5rem;
}
.ll-modal-close {
  position: absolute; top: 1rem; right: 1.25rem;
  background: none; border: none; color: rgba(255,255,255,0.4);
  font-size: 1.8rem; cursor: pointer; line-height: 1;
}
.ll-modal-close:hover { color: var(--gold, #c8952a); }

/* ── Layout helpers ── */
.ll-2col { display: grid; grid-template-columns: 2fr 1fr; gap: 1.25rem; }
.ll-2col-equal { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
.ll-3col { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.9rem; }

/* ── Product thumb ── */
.ll-prod-thumb {
  width: 42px; height: 42px; object-fit: cover;
  border-radius: 6px; border: 1px solid rgba(200,149,42,0.2);
}

/* ── Activity feed ── */
.ll-activity-item {
  padding: 0.55rem 0.85rem;
  background: rgba(0,0,0,0.2);
  border-left: 3px solid rgba(200,149,42,0.5);
  margin-bottom: 0.35rem; border-radius: 0 6px 6px 0;
  font-size: 0.82rem; color: rgba(255,255,255,0.7);
}
.ll-activity-time { color: rgba(255,255,255,0.3); font-size: 0.72rem; margin-top: 0.1rem; }

/* ── Referrer bar ── */
.ll-ref-bar-wrap { margin-bottom: 0.5rem; }
.ll-ref-label { display: flex; justify-content: space-between; font-size: 0.8rem; margin-bottom: 0.2rem; color: rgba(255,255,255,0.7); }
.ll-ref-bar { height: 6px; border-radius: 3px; background: rgba(200,149,42,0.15); }
.ll-ref-bar-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, #1a8a7a, #c8952a); transition: width 0.6s; }

/* ── Affiliate click card ── */
.ll-aff-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px,1fr)); gap: 0.75rem; }
.ll-aff-card {
  background: rgba(200,149,42,0.06); border: 1px solid rgba(200,149,42,0.2);
  border-radius: 8px; padding: 0.85rem; text-align: center;
}
.ll-aff-card-num { font-size: 1.6rem; font-weight: 700; color: var(--gold, #c8952a); font-family: 'Playfair Display', serif; }
.ll-aff-card-lbl { font-size: 0.72rem; color: rgba(255,255,255,0.5); margin-top: 0.2rem; }

/* ── Maintenance btn ── */
.ll-maintenance-btn {
  padding: 0.5rem 1.1rem; border-radius: 8px; font-weight: 700;
  font-size: 0.85rem; cursor: pointer; border: 2px solid;
  transition: all 0.2s; background: none; font-family: inherit;
}

@media (max-width: 900px) {
  .ll-stat-grid { grid-template-columns: repeat(2, 1fr); }
  .ll-2col, .ll-2col-equal, .ll-3col { grid-template-columns: 1fr; }
  .ll-form-row, .ll-form-row-3 { grid-template-columns: 1fr; }
  .ll-admin-title { font-size: 1.5rem; }
}
@media (max-width: 600px) {
  .ll-admin-tab { padding: 0.55rem 0.75rem; font-size: 0.78rem; }
  .ll-stat-val { font-size: 1.5rem; }
}
</style>

<div class="ll-admin-wrap">

  <!-- Top bar -->
  <div class="ll-admin-topbar">
    <div>
      <h1 class="ll-admin-title">🌴 Lizzyland</h1>
      <div class="ll-admin-meta">
        Admin dashboard ·
        <a href="/" style="color:rgba(200,149,42,0.6);">View site →</a> ·
        <a href="/admin/logout" style="color:rgba(255,100,100,0.6);">Log out</a>
      </div>
    </div>
    <button id="maintenanceBtn" onclick="toggleMaintenance()" class="ll-maintenance-btn"
      style="color:#41dc14;border-color:rgba(65,220,20,0.4);background:rgba(65,220,20,0.08);">
      🟢 Site Live
    </button>
  </div>

  <!-- Tab bar -->
  <div class="ll-admin-tabs">
    <button class="ll-admin-tab active" onclick="switchTab('analytics')" id="tab-analytics">📊 Analytics</button>
    <button class="ll-admin-tab"        onclick="switchTab('blog')"      id="tab-blog">✍️ Blog</button>
    <button class="ll-admin-tab"        onclick="switchTab('products')"  id="tab-products">🛍️ Products</button>
    <button class="ll-admin-tab"        onclick="switchTab('orders')"    id="tab-orders">📦 Orders</button>
    <button class="ll-admin-tab"        onclick="switchTab('customers')" id="tab-customers">👥 Subscribers</button>
    <button class="ll-admin-tab"        onclick="switchTab('vouchers')"  id="tab-vouchers">🎟️ Vouchers</button>
    <button class="ll-admin-tab"        onclick="switchTab('mail')"      id="tab-mail">📬 Mail</button>
  </div>

  <!-- ══════════════════════════════════════════════
       TAB 1: ANALYTICS
  ══════════════════════════════════════════════ -->
  <div id="panel-analytics" class="ll-tab-content active">

    <!-- Big numbers row -->
    <div class="ll-stat-grid">
      <div class="ll-stat-card">
        <div class="ll-stat-val" style="color:#5adc28;">
          <%= (typeof todayStats !== 'undefined' && todayStats) ? todayStats.todayVisitors : 0 %>
        </div>
        <div class="ll-stat-lbl">Today's Visitors</div>
        <div class="ll-stat-sub"><%= (typeof todayStats !== 'undefined' && todayStats) ? todayStats.todayPageViews : 0 %> page views</div>
      </div>
      <div class="ll-stat-card">
        <div class="ll-stat-val">
          <%= (typeof weeklyStats !== 'undefined' && weeklyStats) ? weeklyStats.weeklyVisitors : 0 %>
        </div>
        <div class="ll-stat-lbl">This Week</div>
        <!-- 7-day sparkline -->
        <div class="ll-sparkline-wrap" id="sparklineWrap">
          <% if (typeof sparkline !== 'undefined' && sparkline && sparkline.length > 0) { %>
            <% var maxVal = Math.max.apply(null, sparkline.map(function(d){return d.visitors;})) || 1; %>
            <% sparkline.forEach(function(d) { %>
              <div class="ll-spark-bar" title="<%= d.label %>: <%= d.visitors %>"
                style="height:<%= Math.max(3, Math.round((d.visitors/maxVal)*36)) %>px;">
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>
      <div class="ll-stat-card">
        <div class="ll-stat-val">
          <%= (typeof monthlyStats !== 'undefined' && monthlyStats) ? monthlyStats.monthlyVisitors : 0 %>
        </div>
        <div class="ll-stat-lbl">This Month</div>
        <div class="ll-stat-sub">unique visitors</div>
      </div>
      <div class="ll-stat-card">
        <div class="ll-stat-val" style="color:#28b89e;">
          <%= (typeof affClicks !== 'undefined' && affClicks) ? affClicks.reduce(function(s,c){return s+(c.clicks||0);},0) : 0 %>
        </div>
        <div class="ll-stat-lbl">Affiliate Clicks</div>
        <div class="ll-stat-sub">this week</div>
      </div>
    </div>

    <div class="ll-2col">

      <!-- Traffic chart -->
      <div class="ll-admin-box">
        <div class="ll-admin-box-title">Daily Visitors — Last 7 Days</div>
        <canvas id="trafficChart" style="max-height:200px;"></canvas>
      </div>

      <!-- Top pages -->
      <div class="ll-admin-box">
        <div class="ll-admin-box-title">🔥 Top Pages This Week</div>
        <table class="ll-admin-table">
          <thead><tr><th>#</th><th>Page</th><th style="text-align:right;">Views</th></tr></thead>
          <tbody>
            <% if (typeof popularPages !== 'undefined' && popularPages && popularPages.length > 0) { %>
              <% popularPages.slice(0,8).forEach(function(p, i) { %>
              <tr>
                <td style="opacity:0.4;font-size:0.75rem;"><%= i+1 %></td>
                <td style="font-size:0.8rem;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= p.page_path %></td>
                <td style="text-align:right;font-weight:700;color:var(--gold,#c8952a);"><%= p.views %></td>
              </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="3" style="text-align:center;opacity:0.3;padding:1.5rem;">No data yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>

    <div class="ll-2col">

      <!-- Referrers -->
      <div class="ll-admin-box">
        <div class="ll-admin-box-title">🌐 Where Visitors Came From</div>
        <% if (typeof referrers !== 'undefined' && referrers && referrers.length > 0) { %>
          <% var maxRef = Math.max.apply(null, referrers.map(function(r){return r.visits;})) || 1; %>
          <% referrers.slice(0,8).forEach(function(r) { %>
          <div class="ll-ref-bar-wrap">
            <div class="ll-ref-label">
              <span><%= r.domain || 'Direct' %></span>
              <span style="color:rgba(200,149,42,0.7);font-weight:700;"><%= r.visits %></span>
            </div>
            <div class="ll-ref-bar">
              <div class="ll-ref-bar-fill" style="width:<%= Math.round((r.visits/maxRef)*100) %>%;"></div>
            </div>
          </div>
          <% }); %>
        <% } else { %>
          <p style="opacity:0.3;text-align:center;padding:1.5rem;font-size:0.85rem;">No referrer data yet — visitors coming direct</p>
        <% } %>
      </div>

      <!-- Affiliate clicks -->
      <div class="ll-admin-box">
        <div class="ll-admin-box-title">💰 Affiliate Clicks This Week</div>
        <% if (typeof affClicks !== 'undefined' && affClicks && affClicks.length > 0) { %>
          <div class="ll-aff-grid">
            <% affClicks.forEach(function(c) { %>
            <div class="ll-aff-card">
              <div class="ll-aff-card-num"><%= c.clicks %></div>
              <div class="ll-aff-card-lbl"><%= c.link_name %></div>
              <div style="margin-top:0.25rem;"><span class="ll-badge ll-badge-blue"><%= c.door %></span></div>
            </div>
            <% }); %>
          </div>
        <% } else { %>
          <p style="opacity:0.3;text-align:center;padding:1.5rem;font-size:0.85rem;">No clicks yet — affiliate links need /go/ routing</p>
        <% } %>
      </div>

    </div>

    <!-- Recent activity -->
    <div class="ll-admin-box">
      <div class="ll-admin-box-title">⚡ Live Activity Feed</div>
      <div style="max-height:280px;overflow-y:auto;">
        <% if (typeof recentActivity !== 'undefined' && recentActivity && recentActivity.length > 0) { %>
          <% recentActivity.forEach(function(a) { %>
          <div class="ll-activity-item">
            <span style="color:rgba(200,149,42,0.8);font-weight:600;"><%= a.page_path %></span>
            <% if (a.referrer) { %><span style="opacity:0.4;font-size:0.75rem;"> · via <%= a.referrer.substring(0,40) %></span><% } %>
            <div class="ll-activity-time"><%= a.created_at ? new Date(a.created_at).toLocaleString('en-ZA') : '' %></div>
          </div>
          <% }); %>
        <% } else { %>
          <p style="opacity:0.3;text-align:center;padding:1.5rem;">No activity yet — share your site!</p>
        <% } %>
      </div>
    </div>

  </div><!-- /panel-analytics -->

  <!-- ══════════════════════════════════════════════
       TAB 2: BLOG
  ══════════════════════════════════════════════ -->
  <div id="panel-blog" class="ll-tab-content">

    <div class="ll-2col">

      <!-- Write -->
      <div class="ll-admin-box">
        <div class="ll-admin-box-title">✍️ Write a Post</div>
        <form method="POST" action="/admin/blog" enctype="multipart/form-data">
          <div class="ll-form-group">
            <label>Title *</label>
            <input type="text" name="title" required placeholder="e.g. The La Dolce Vita morning routine...">
          </div>
          <div class="ll-form-row">
            <div class="ll-form-group">
              <label>Door / Category</label>
              <select name="category">
                <option value="general">🌴 General</option>
                <option value="health">🚪 Health</option>
                <option value="wealth">🚪 Wealth</option>
                <option value="happiness">🚪 Happiness</option>
              </select>
            </div>
            <div class="ll-form-group">
              <label>Status</label>
              <select name="status">
                <option value="draft">Draft</option>
                <option value="published">Published</option>
                <option value="scheduled">Scheduled</option>
              </select>
            </div>
          </div>
          <div class="ll-form-group" id="scheduleGroup" style="display:none;">
            <label>Publish at</label>
            <input type="datetime-local" name="scheduled_at">
          </div>
          <div class="ll-form-group">
            <label>Body</label>
            <textarea name="body" rows="12" placeholder="Start typing your musings here... 🌴&#10;&#10;La dolce vita, baby."></textarea>
          </div>
          <div class="ll-form-row">
            <div class="ll-form-group">
              <label>Feature Photo (upload)</label>
              <input type="file" name="image" accept="image/*" style="padding:0.4rem;">
            </div>
            <div class="ll-form-group">
              <label>Or Image URL</label>
              <input type="url" name="image_url" placeholder="https://...">
            </div>
          </div>
          <div class="ll-form-group">
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;text-transform:none;letter-spacing:0;">
              <input type="checkbox" name="send_newsletter" value="1" style="width:auto;accent-color:#c8952a;">
              <span style="font-size:0.85rem;color:rgba(255,255,255,0.6);">Send to newsletter subscribers when published</span>
            </label>
          </div>
          <button type="submit" class="ll-btn-primary" style="width:100%;">Publish Post 🌴</button>
        </form>
      </div>

      <!-- Post-by-phone sidebar -->
      <div>
        <div class="ll-admin-box">
          <div class="ll-admin-box-title">📧 Post by Email</div>
          <p style="color:rgba(255,255,255,0.45);font-size:0.83rem;margin:0 0 1rem;line-height:1.6;">
            Email your musings from the beach — subject line becomes the title, body becomes the post.
          </p>
          <div style="background:rgba(200,149,42,0.07);border-radius:8px;padding:0.85rem;margin-bottom:0.85rem;">
            <div style="font-size:0.7rem;color:rgba(200,149,42,0.7);font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.4rem;">Post-in address</div>
            <code style="font-size:0.82rem;color:#e8b84b;">post@lizzyland.xyz</code>
